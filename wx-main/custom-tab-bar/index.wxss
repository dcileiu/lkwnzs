.tabbar-wrapper {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  box-sizing: border-box;
  z-index: 999;
  pointer-events: none;
}

.button-wrap {
  position: relative;
  width: 100%;
  max-width: 694rpx;
  margin: 0 auto;
  z-index: 2;
  pointer-events: auto;
  box-sizing: border-box;
}

.glass-button {
  position: relative;
  z-index: 3;
  display: flex;
  width: 100%;
  gap: 6rpx;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.65);
  border-radius: 999rpx;
  backdrop-filter: blur(24rpx);
  box-shadow: 0 16rpx 40rpx rgba(31, 41, 55, 0.12);
  box-sizing: border-box;
}

.tab-span {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  justify-content: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  color: rgba(31, 41, 55, 0.78);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-sizing: border-box;
}

.tab-span:active {
  transform: scale(0.96);
}

.tab-span.active {
  color: #ffffff;
  background: linear-gradient(135deg, #667eea 0%, #7c9cff 100%);
  box-shadow: 0 10rpx 24rpx rgba(102, 126, 234, 0.28);
}
