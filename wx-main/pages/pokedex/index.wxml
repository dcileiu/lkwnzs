<view class="page-container">
  <!-- Pokedex Stats -->
  <view class="pokedex-stats">
    <view class="stat-item">
      <text class="stat-num">{{collectedCount}}</text>
      <text class="stat-label">已收集</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">总图鉴</text>
    </view>
  </view>

  <!-- Search & Filter -->
  <view class="search-box">
    <icon type="search" size="14" color="#999"></icon>
    <input class="search-input" placeholder="输入精灵名称..." bindinput="onSearchInput" bindconfirm="onSearch" />
  </view>
  
  <scroll-view class="element-tabs" scroll-x>
    <view class="tabs-wrap">
      <block wx:for="{{elements}}" wx:key="*this">
        <view class="tab-item {{currentElement === item ? 'active' : ''}}" bindtap="switchElement" data-element="{{item}}">
          {{item}}
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- Grid List -->
  <scroll-view class="elf-grid-scroll" scroll-y>
    <view class="elf-grid">
      <block wx:for="{{elves}}" wx:key="id">
        <view class="elf-card" bindtap="goToDetail" data-id="{{item.id}}">
          <view class="elf-avatar-wrap">
            <image src="{{item.coverImage || item.avatar || '/assets/default-elf.png'}}" class="elf-avatar"></image>
          </view>
          <text class="elf-name">{{item.name}}</text>
          <view class="elf-tags">
            <text class="tag-element">{{item.element}}系</text>
            <text class="tag-rarity {{item.rarity}}">{{item.rarity}}</text>
          </view>
        </view>
      </block>
    </view>
    <view wx:if="{{elves.length === 0}}" class="empty-state">没有找到对应的精灵</view>
  </scroll-view>
</view>
