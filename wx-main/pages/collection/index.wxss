.page-container {
  width: 100%;
  padding: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #999;
}

.egg-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.egg-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  min-width: 0;
  box-sizing: border-box;
}

.egg-img-wrap {
  width: 120rpx;
  height: 120rpx;
  background: #f0f4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.egg-img-wrap.active {
  border-color: #1890ff;
  background: #e6f7ff;
}

.egg-img {
  width: 80rpx;
  height: 80rpx;
}

.egg-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 8rpx;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.egg-rules-count {
  font-size: 22rpx;
  color: #999;
}

.detail-panel {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 25rpx;
}

.detail-info {
  flex: 1;
  min-width: 0;
}

.detail-egg-icon {
  width: 100rpx;
  height: 100rpx;
  background: #f0f4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-egg-img {
  width: 70rpx;
  height: 70rpx;
}

.detail-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.detail-desc {
  font-size: 24rpx;
  color: #999;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.hatch-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.hatch-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hatch-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 15rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.hatch-elf-icon {
  width: 70rpx;
  height: 70rpx;
  background: #fff;
  border-radius: 50%;
  padding: 8rpx;
}

.hatch-elf-img {
  width: 100%;
  height: 100%;
}

.hatch-elf-info {
  flex: 1;
  min-width: 0;
}

.hatch-elf-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hatch-elf-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-element-sm {
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.tag-rarity-sm {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: #e6f7ff;
  color: #1890ff;
}
.tag-rarity-sm.SSR { color: #eb2f96; background: #fff0f6; }
.tag-rarity-sm.SR  { color: #722ed1; background: #f9f0ff; }
.tag-rarity-sm.UR  { color: #fa8c16; background: #fff7e6; }

.hatch-prob {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 120rpx;
}

.prob-bar-bg {
  width: 120rpx;
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.prob-bar {
  height: 100%;
  background: #1890ff;
  border-radius: 6rpx;
}

.prob-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #1890ff;
}

.detail-tip {
  margin-top: 25rpx;
  background: #fffbe6;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #ad6800;
  line-height: 1.6;
  box-sizing: border-box;
  word-break: break-all;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
