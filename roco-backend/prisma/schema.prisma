generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String              @id @default(cuid())
  openId       String              @unique
  nickname     String?
  avatar       String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  comments     Comment[]
  collections  UserElfCollection[]
  interactions UserInteraction[]
  browseHistory UserBrowseHistory[]
}

model Author {
  id          String    @id @default(cuid())
  name        String
  avatar      String?
  bio         String?
  guidesCount Int       @default(0)
  totalLikes  Int       @default(0)
  createdAt   DateTime  @default(now())
  articles    Article[]
}

model Article {
  id              String            @id @default(cuid())
  title           String
  summary         String?
  thumbnail       String?
  content         String
  contentMarkdown String?
  category        String
  readingTime     Int               @default(5)
  views           Int               @default(0)
  likes           Int               @default(0)
  bookmarks       Int               @default(0)
  isHot           Boolean           @default(false)
  isVisible       Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  authorId        String
  author          Author            @relation(fields: [authorId], references: [id])
  comments        Comment[]
  interactions    UserInteraction[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  articleId String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model UserInteraction {
  id        String   @id @default(cuid())
  type      String
  createdAt DateTime @default(now())
  userId    String
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId, type])
}

model UserBrowseHistory {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  viewedAt   DateTime @default(now())
  viewCount  Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, viewedAt])
  @@index([targetType, targetId])
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  content   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isVisible, updatedAt])
}

model Elf {
  id                   String                   @id @default(cuid())
  name                 String
  avatar               String?
  element              String
  rarity               String
  group                String?
  category             String?
  height               String?
  weight               String?
  raceValue            String?
  eggImageUrl          String?
  fruitImageUrl        String?
  totalStats           Int                      @default(0)
  hp                   Int                      @default(0)
  attack               Int                      @default(0)
  defense              Int                      @default(0)
  speed                Int                      @default(0)
  isHot                Boolean                  @default(false)
  detailQueryCount     Int                      @default(0)
  tags                 String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  hatchRules           HatchRule[]
  collections          UserElfCollection[]
  images               ElfImage[]
  learnableSkillStones SkillStoneLearnableElf[]
  evolutionParentLinks ElfEvolution[]           @relation("ElfEvolutionParent")
  evolutionChildLinks  ElfEvolution[]           @relation("ElfEvolutionChild")
}

model Egg {
  id        String      @id @default(cuid())
  name      String
  avatar    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  rules     HatchRule[]
  images    EggImage[]
}

model EggGroup {
  id          String        @id
  name        String
  description String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  elves       EggGroupElf[]

  @@index([sortOrder])
}

model EggGroupElf {
  id         String   @id @default(cuid())
  groupId    String
  name       String
  image      String?
  attributes String?
  attrNames  String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  group      EggGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId, sortOrder])
  @@index([name])
}

model HatchRule {
  id          String   @id @default(cuid())
  eggId       String
  elfId       String
  minHeight   Float
  maxHeight   Float
  minWeight   Float
  maxWeight   Float
  probability Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  elf         Elf      @relation(fields: [elfId], references: [id])
  egg         Egg      @relation(fields: [eggId], references: [id])
}

model UserElfCollection {
  id        String   @id @default(cuid())
  userId    String
  elfId     String
  createdAt DateTime @default(now())
  elf       Elf      @relation(fields: [elfId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, elfId])
}

model ElfImage {
  id        String   @id @default(cuid())
  elfId     String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  elf       Elf      @relation(fields: [elfId], references: [id], onDelete: Cascade)

  @@index([elfId, sortOrder])
}

model EggImage {
  id        String   @id @default(cuid())
  eggId     String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  egg       Egg      @relation(fields: [eggId], references: [id], onDelete: Cascade)

  @@index([eggId, sortOrder])
}

model ItemCategory {
  id          String              @id
  name        String
  icon        String?
  description String?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  fields      ItemCategoryField[]
  items       Item[]

  @@index([sortOrder])
}

model ItemCategoryField {
  id          String       @id @default(cuid())
  categoryId  String
  key         String
  label       String
  type        String
  required    Boolean      @default(false)
  placeholder String?
  optionsJson String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    ItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@index([categoryId, sortOrder])
}

model Item {
  id             String                   @id @default(cuid())
  categoryId     String
  name           String
  image          String?
  desc           String?
  rarity         String?
  effect         String?
  obtain         String?
  attr           String?
  extraJson      String?
  sortOrder      Int                      @default(0)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  category       ItemCategory             @relation(fields: [categoryId], references: [id])
  learnableElves SkillStoneLearnableElf[]
  shopEntries    ShopItem[]

  @@unique([categoryId, name])
  @@index([categoryId, sortOrder])
  @@index([name])
}

model ShopItem {
  id        String    @id @default(cuid())
  itemId    String
  price     Int       @default(0)
  currency  String    @default("gold")
  stock     Int?
  enabled   Boolean   @default(true)
  roundSlot Int?
  sortOrder Int       @default(0)
  startAt   DateTime?
  endAt     DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([enabled, sortOrder])
  @@index([startAt])
  @@index([endAt])
}

model SkillStoneLearnableElf {
  id        String   @id @default(cuid())
  itemId    String
  elfId     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  elf       Elf      @relation(fields: [elfId], references: [id], onDelete: Cascade)

  @@unique([itemId, elfId])
  @@index([elfId])
  @@index([itemId, sortOrder])
}

model EvolutionChain {
  id        String         @id @default(cuid())
  name      String?
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  links     ElfEvolution[]
}

model ElfEvolution {
  id          String         @id @default(cuid())
  chainId     String
  parentElfId String?
  childElfId  String
  stage       Int            @default(1)
  sortOrder   Int            @default(0)
  requirement String?
  note        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  chain       EvolutionChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  parentElf   Elf?           @relation("ElfEvolutionParent", fields: [parentElfId], references: [id], onDelete: Cascade)
  childElf    Elf            @relation("ElfEvolutionChild", fields: [childElfId], references: [id], onDelete: Cascade)

  @@unique([chainId, childElfId])
  @@index([chainId, stage, sortOrder])
  @@index([parentElfId])
}
