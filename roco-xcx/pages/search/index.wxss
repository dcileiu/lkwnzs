.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx;
  background: #f5f7fb;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 14rpx 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.03);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  font-size: 24rpx;
  color: #667eea;
}

.tab-bar {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0;
}

.tab-item {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #666;
  font-size: 24rpx;
}

.tab-item.active {
  background: #667eea;
  color: #fff;
}

.result-scroll {
  height: calc(100vh - 220rpx);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin: 8rpx 0 16rpx;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  color: #222;
  margin-bottom: 8rpx;
}

.card-meta {
  font-size: 22rpx;
  color: #888;
}

.elf-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.elf-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f4ff;
}

.elf-info {
  flex: 1;
  min-width: 0;
}

.empty-state {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 28rpx 0;
}
