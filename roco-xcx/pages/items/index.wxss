.page-container {
  width: 100%;
  padding: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  position: relative;
  height: 460rpx;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0.25) 55%,
    rgba(25, 51, 93, 0.78) 86%,
    #19335d 100%
  );
}

.top-nav {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 0 200rpx 0 20rpx;
}

.nav-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(20, 43, 82, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.nav-back {
  flex-shrink: 0;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 320rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #f9eec4;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 4rpx 14rpx rgba(8, 16, 36, 0.45);
  pointer-events: none;
}

.hero-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 220rpx 20rpx 0;
  box-sizing: border-box;
}

.search-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 74rpx;
  padding: 0 24rpx 0 28rpx;
  border-radius: 40rpx;
  background: linear-gradient(
    180deg,
    rgba(107, 144, 170, 0.58) 0%,
    rgba(76, 117, 150, 0.42) 52%,
    rgba(62, 102, 138, 0.5) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    inset 0 -8rpx 16rpx rgba(21, 45, 78, 0.16),
    0 10rpx 24rpx rgba(8, 22, 49, 0.22);
  backdrop-filter: blur(14px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #fff0c9;
}

.search-clear {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 30rpx;
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.86);
  background: rgba(255, 255, 255, 0.14);
}

.item-stats {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 74rpx;
  padding: 0 22rpx;
  border-radius: 40rpx;
  background: rgba(13, 28, 56, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12),
    0 6rpx 16rpx rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  color: #fff;
  box-sizing: border-box;
}

.stat-item {
  min-width: 58rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #fff;
}

.stat-label {
  margin-top: 2rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.72);
}

.stat-divider {
  width: 1rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.22);
}

.items-main {
  position: relative;
  z-index: 3;
  margin-top: -40rpx;
  padding: 0 18rpx 20rpx;
  box-sizing: border-box;
}

.tabs-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
  padding: 4rpx 0 8rpx;
}

.tabs {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding-right: 20rpx;
}

.tab-item {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 124rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 188rpx;
  background: rgba(34, 61, 113, 0.6);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  overflow: hidden;
  box-sizing: border-box;
  flex-shrink: 0;
}

.tab-item.active {
  background: rgba(34, 61, 113, 0.82);
  box-shadow: 0 8rpx 18rpx rgba(16, 22, 62, 0.28);
}

.tab-active-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.tab-label,
.tab-count {
  position: relative;
  z-index: 1;
}

.tab-label {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(240, 246, 255, 0.92);
  line-height: 1;
}

.tab-count {
  min-width: 28rpx;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.14);
  box-sizing: border-box;
}

.tab-item.active .tab-label {
  color: #fff3d4;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(20, 30, 80, 0.5);
}

.item-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  padding-top: 6rpx;
}

.item-card {
  position: relative;
  min-height: 280rpx;
  padding: 24rpx 10rpx 18rpx;
  border-radius: 16rpx;
  background-image: url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/elf-card.webp");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  box-sizing: border-box;
  overflow: hidden;
}

.item-image-wrap {
  width: 110rpx;
  height: 110rpx;
  margin: 14rpx auto 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-image {
  width: 110rpx;
  height: 110rpx;
}

.item-image-fallback {
  width: 90rpx;
  height: 90rpx;
  border-radius: 22rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #b08a4d;
  background: rgba(255, 239, 200, 0.72);
}

.item-name {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #2c2236;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 6rpx;
  box-sizing: border-box;
}

.item-tags {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.item-category,
.item-rarity {
  max-width: 78rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.item-category {
  color: #5b4a82;
  background: rgba(91, 74, 130, 0.1);
  border: 1rpx solid rgba(91, 74, 130, 0.18);
}

.item-rarity {
  color: #c0492a;
  background: rgba(255, 236, 214, 0.9);
  border: 1rpx solid rgba(216, 93, 58, 0.36);
}

.item-summary {
  display: -webkit-box;
  margin-top: 8rpx;
  min-height: 46rpx;
  font-size: 18rpx;
  line-height: 1.25;
  color: rgba(44, 34, 54, 0.72);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.learnable-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  font-weight: 700;
  color: #fff3d4;
  background: linear-gradient(180deg, #6c4ad6 0%, #4d2eb1 100%);
  box-shadow: 0 4rpx 8rpx rgba(76, 46, 177, 0.3);
}

.empty-state {
  text-align: center;
  padding: 120rpx 0 80rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
}

.load-more-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
  padding: 24rpx 0 10rpx;
}
