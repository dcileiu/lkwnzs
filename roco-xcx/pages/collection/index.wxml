<view class="page-container">
  <view class="page-header">
    <text class="page-title">宠物蛋图鉴</text>
    <text class="page-sub">点击任意宠物蛋，查看可孵化精灵与概率区间</text>
  </view>

  <view wx:if="{{eggs.length}}" class="egg-grid">
    <block wx:for="{{eggs}}" wx:key="id">
      <view class="egg-card" bindtap="showEggDetail" data-id="{{item.id}}" data-index="{{index}}">
        <view class="egg-img-wrap {{activeEggIndex === index ? 'active' : ''}}">
          <image
            class="egg-img"
            src="{{item.coverImage || item.avatar || item.image || '/assets/default-egg.png'}}"
            mode="aspectFit"
          ></image>
        </view>
        <text class="egg-name">{{item.name}}</text>
        <text class="egg-rules-count">{{item.ruleCount || 0}} 条规则</text>
      </view>
    </block>
  </view>

  <view wx:else class="empty-state">暂时还没有可展示的宠物蛋</view>

  <view wx:if="{{selectedEgg}}" class="detail-panel">
    <view class="detail-header">
      <view class="detail-egg-icon">
        <image
          class="detail-egg-img"
          src="{{selectedEgg.coverImage || selectedEgg.avatar || selectedEgg.image || '/assets/default-egg.png'}}"
          mode="aspectFit"
        ></image>
      </view>
      <view class="detail-info">
        <text class="detail-name">{{selectedEgg.name}}</text>
        <text class="detail-desc">共 {{selectedEgg.rules.length}} 种孵化结果</text>
      </view>
    </view>

    <scroll-view wx:if="{{selectedEgg.images.length}}" class="detail-gallery" scroll-x>
      <view class="detail-gallery-track">
        <block wx:for="{{selectedEgg.images}}" wx:key="id">
          <view class="detail-gallery-item">
            <image class="detail-gallery-img" src="{{item.url}}" mode="aspectFill"></image>
          </view>
        </block>
      </view>
    </scroll-view>

    <view class="divider"></view>

    <view class="hatch-title">孵化结果</view>
    <view class="hatch-list">
      <block wx:for="{{selectedEgg.rules}}" wx:key="id">
        <view class="hatch-item" bindtap="goElfDetail" data-id="{{item.elf.id}}">
          <view class="hatch-elf-icon">
            <image
              class="hatch-elf-img"
              src="{{item.elf.coverImage || item.elf.avatar || '/assets/default-elf.png'}}"
              mode="aspectFit"
            ></image>
          </view>

          <view class="hatch-elf-info">
            <text class="hatch-elf-name">{{item.elf.name}}</text>
            <view class="hatch-elf-meta">
              <block wx:for="{{item.elf.elements}}" wx:key="*this">
                <text class="tag-element-sm">{{item}}系</text>
              </block>
              <text class="tag-rarity-sm {{item.elf.rarity}}">{{item.elf.rarity}}</text>
            </view>
          </view>

          <view class="hatch-prob">
            <view class="prob-bar-bg">
              <view class="prob-bar" style="width: {{item.probability}}%;"></view>
            </view>
            <text class="prob-text">{{item.probability}}%</text>
          </view>
        </view>
      </block>
    </view>

    <view class="detail-tip">
      概率仅供参考，具体孵化结果以游戏内表现为准。
    </view>
  </view>
</view>
