<scroll-view class="page-container" scroll-y enable-flex>
  <view class="hero">
    <image class="hero-bg" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/articles-bg.webp" mode="aspectFill"></image>
    <view class="hero-overlay"></view>
    <view class="top-nav" style="padding-top: {{navTopPadding}}px;">
      <view class="nav-btn nav-back" bindtap="onBackTap">
        <image class="nav-back-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/bg-left.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">✦ 远行商人 ✦</text>
    </view>
    <view class="hero-content">
      <view class="hero-tagline">今日精选好物，限时上架</view>
      <view class="shop-stats">
        <view class="stat-item">
          <text class="stat-num">{{totalCount}}</text>
          <text class="stat-label">在售商品</text>
        </view>
        <view class="stat-item stat-item-round">
          <text class="stat-num stat-round">{{todayRoundText}}</text>
          <text class="stat-label">当前轮次</text>
        </view>
      </view>
    </view>
  </view>

  <view class="shop-main">
    <view wx:if="{{roundGroups.length}}">
      <block wx:for="{{roundGroups}}" wx:key="round" wx:for-item="group">
        <view class="round-section">
          <view class="round-header">
            <text class="round-title">{{group.roundLabel}}</text>
            <text class="round-time">{{group.timeRange}}</text>
          </view>
          <view class="round-body {{group.isCurrent ? '' : 'round-body--masked'}}">
            <view wx:if="{{group.items.length}}" class="shop-grid">
              <block wx:for="{{group.items}}" wx:key="id" wx:for-item="shop">
                <view
                  class="shop-card"
                  bindtap="showItemDetail"
                  data-id="{{shop.id}}"
                  data-locked="{{!group.isCurrent}}"
                >
                <view class="shop-image-wrap">
                  <image
                    wx:if="{{shop.imageUrl}}"
                    class="shop-image"
                    src="{{shop.imageUrl}}"
                    mode="aspectFit"
                    lazy-load
                    binderror="onItemImageError"
                    data-id="{{shop.id}}"
                  ></image>
                  <text wx:else class="shop-image-fallback">{{shop.fallbackText}}</text>
                </view>

                <text class="shop-name">{{shop.name}}</text>
                <view class="shop-tags">
                  <text class="shop-category">{{shop.categoryName}}</text>
                  <text wx:if="{{shop.rarityLabel}}" class="shop-rarity">{{shop.rarityLabel}}</text>
                </view>

                <view class="shop-price-row">
                  <text class="shop-price">{{shop.priceLabel}}</text>
                  <text class="shop-currency">{{shop.currencyLabel}}</text>
                </view>

                <view class="shop-meta">
                  <text class="shop-stock">限购 {{shop.stockLabel}}</text>
                </view>

                <view wx:if="{{shop.periodLabel}}" class="shop-period">⏰ {{shop.periodLabel}}</view>
                <view wx:if="{{shop.note}}" class="shop-note">{{shop.note}}</view>
                </view>
              </block>
            </view>
            <view wx:else class="round-empty">本轮暂无商品</view>
            <view wx:if="{{!group.isCurrent}}" class="round-mask">
              <text class="round-mask-text">{{group.maskText}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view wx:elif="{{!isLoading}}" class="empty-state">
      <text>今天暂无在售商品</text>
      <text class="empty-sub">请稍后再来查看新的轮次</text>
    </view>
  </view>
</scroll-view>
