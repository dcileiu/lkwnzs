.page-container {
  width: 100%;
  padding: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  position: relative;
  height: 460rpx;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0.25) 55%,
    rgba(25, 51, 93, 0.78) 86%,
    #193157 100%
  );
}

.top-nav {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 0 200rpx 0 20rpx;
}

.nav-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(20, 43, 82, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.nav-back {
  flex-shrink: 0;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 320rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #f9eec4;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 4rpx 14rpx rgba(8, 16, 36, 0.45);
  pointer-events: none;
}

.hero-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 20rpx 80rpx;
  box-sizing: border-box;
}

.hero-tagline {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff3d4;
  text-shadow: 0 4rpx 14rpx rgba(8, 16, 36, 0.45);
}

.shop-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  min-height: 74rpx;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  background: rgba(13, 28, 56, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12),
    0 6rpx 16rpx rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  color: #fff;
  box-sizing: border-box;
}

.stat-item {
  min-width: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-num {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #fff;
  text-align: center;
}

.stat-label {
  margin-top: 2rpx;
  font-size: 18rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.72);
}

.stat-item-round {
  border-left: 1rpx solid rgba(255, 255, 255, 0.22);
  padding-left: 14rpx;
}

.stat-round {
  font-size: 24rpx;
}

.shop-main {
  position: relative;
  z-index: 3;
  margin-top: -40rpx;
  padding: 0 18rpx 20rpx;
  box-sizing: border-box;
}

.round-section + .round-section {
  margin-top: 14rpx;
}

.round-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 4rpx 2rpx 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(12, 27, 54, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.round-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff3d4;
}

.round-time {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.76);
}

.round-empty {
  text-align: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.62);
  padding: 24rpx 0 14rpx;
}

.shop-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  padding-top: 6rpx;
}

.shop-card {
  position: relative;
  min-height: 250rpx;
  padding: 14rpx 8rpx 12rpx;
  border-radius: 14rpx;
  background-image: url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/elf-card.webp");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shop-image-wrap {
  width: 86rpx;
  height: 86rpx;
  margin: 4rpx auto 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shop-image {
  width: 86rpx;
  height: 86rpx;
}

.shop-image-fallback {
  width: 110rpx;
  height: 110rpx;
  border-radius: 28rpx;
  line-height: 110rpx;
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #b08a4d;
  background: rgba(255, 239, 200, 0.72);
}

.shop-name {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #2c2236;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 2rpx;
  box-sizing: border-box;
}

.shop-tags {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.shop-category,
.shop-rarity {
  max-width: 92rpx;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  font-size: 14rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.shop-category {
  color: #5b4a82;
  background: rgba(91, 74, 130, 0.1);
  border: 1rpx solid rgba(91, 74, 130, 0.18);
}

.shop-rarity {
  color: #c0492a;
  background: rgba(255, 236, 214, 0.9);
  border: 1rpx solid rgba(216, 93, 58, 0.36);
}

.shop-price-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.shop-price {
  font-size: 28rpx;
  font-weight: 800;
  color: #c44b1a;
  line-height: 1.1;
  text-shadow: 0 2rpx 0 rgba(255, 240, 200, 0.6);
}

.shop-currency {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14rpx;
  font-weight: 600;
  color: #6c5333;
  line-height: 1;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 217, 142, 0.65);
  border: 1rpx solid rgba(196, 75, 26, 0.3);
}

.shop-meta {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.shop-stock {
  font-size: 14rpx;
  color: rgba(44, 34, 54, 0.7);
}

.shop-period {
  margin-top: 6rpx;
  font-size: 14rpx;
  color: #5b4a82;
  background: rgba(91, 74, 130, 0.08);
  padding: 3rpx 8rpx;
  border-radius: 8rpx;
  text-align: center;
  line-height: 1.3;
}

.shop-note {
  margin-top: 6rpx;
  font-size: 14rpx;
  color: rgba(44, 34, 54, 0.7);
  text-align: center;
  line-height: 1.3;
  padding: 0 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 120rpx 0 80rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}
