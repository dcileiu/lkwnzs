.page-container {
  width: 100%;
  padding: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  position: relative;
  min-height: 332rpx;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  display: block;
  width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0) 45%,
    rgba(25, 51, 93, 0.35) 65%,
    rgba(25, 51, 93, 0.75) 85%,
    #19335d 100%
  );
}

.hero-content {
  position: absolute;
  inset: 0;
  padding: 240rpx 20rpx 0;
  z-index: 2;
  box-sizing: border-box;
}

.search-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
  width: 370rpx;
  height: 74rpx;
  padding: 0 28rpx;
  border-radius: 40rpx;
  background: linear-gradient(
    180deg,
    rgba(107, 144, 170, 0.58) 0%,
    rgba(76, 117, 150, 0.42) 52%,
    rgba(62, 102, 138, 0.5) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    inset 0 -8rpx 16rpx rgba(21, 45, 78, 0.16),
    0 10rpx 24rpx rgba(8, 22, 49, 0.22);
  backdrop-filter: blur(14px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff0c9;
}

.home-main {
  position: relative;
  margin-top: -80rpx;
  z-index: 3;
}

.quick-actions {
  width: calc(100% - 40rpx);
  white-space: nowrap;
  margin: 18rpx 20rpx 24rpx;
}

.quick-card {
  position: relative;
  display: inline-block;
  width: 166rpx;
  height: 300rpx;
  margin-right: 14rpx;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 18rpx rgba(10, 24, 53, 0.25);
  box-sizing: border-box;
  vertical-align: top;
}

.quick-card:last-child {
  margin-right: 0;
}

.quick-card.is-coming .quick-mask {
  background: linear-gradient(
    180deg,
    rgba(6, 18, 41, 0.1) 0%,
    rgba(6, 18, 41, 0.3) 100%
  );
}

.quick-bg,
.elf-card-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.quick-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.08) 0%,
    rgba(6, 18, 41, 0.16) 48%,
    rgba(6, 18, 41, 0.42) 100%
  );
}

.quick-body {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 188rpx 12rpx 14rpx;
  color: #fff;
  text-align: center;
  box-sizing: border-box;
}

.quick-title {
  display: block;
  width: 100%;
  font-size: 28rpx;
  line-height: 1.18;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #ffffff;
  text-shadow: 0 3rpx 8rpx rgba(6, 16, 38, 0.35);
  white-space: nowrap;
}

.quick-sub {
  display: block;
  width: 100%;
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.2;
  opacity: 0.92;
  white-space: nowrap;
}

.quick-arrow {
  position: absolute;
  right: 16rpx;
  bottom: 14rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  font-size: 34rpx;
  line-height: 30rpx;
  color: rgba(255, 255, 255, 0.94);
  background: rgba(255, 255, 255, 0.16);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}

.section {
  margin: 0 20rpx 22rpx;
  background: transparent;
  border: 0;
  border-radius: 0;
  padding: 0;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f9eec4;
}

.more {
  font-size: 24rpx;
  color: #f9eec4;
}

.guide-section {
  padding-bottom: 4rpx;
  margin-bottom: 10rpx;
}

.guide-swiper {
  height: 188rpx;
}
.art-item {
  height: 100%;
}
.guide-card {
  position: relative;
  background: #f7e3cf;
  border: 2rpx solid #f7e3cf;
  border-radius: 16rpx;
  height: 178rpx;
  padding: 14rpx;
  box-sizing: border-box;
  display: flex;
  gap: 16rpx;
}

.guide-cover {
  width: 214rpx;
  height: 148rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.12);
}

.guide-info {
  flex: 1;
  min-width: 0;
  padding-top: 6rpx;
  display: flex;
  flex-direction: column;
}

.guide-title {
  display: -webkit-box;
  font-size: 30rpx;
  font-weight: 700;
  color: #252c38;
  line-height: 1.5;
  max-height: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.guide-meta {
  margin-top: auto;
  font-size: 26rpx;
  color: #7d7d7d;
  display: flex;
  justify-content: space-between;
}

.tag-hot {
  font-size: 22rpx;
  background: #f05f4a;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 700;
}

.dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin: 0;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(244, 229, 194, 0.45);
}

.dot.active {
  background: #f4e5c2;
}

.elf-scroll {
  white-space: nowrap;
  width: 100%;
}

.elf-card {
  position: relative;
  display: inline-block;
  margin-right: 14rpx;
  width: 166rpx;
  min-height: 300rpx;
  border-radius: 18rpx;
  overflow: hidden;
  box-sizing: border-box;
  padding-bottom: 8rpx;
}

.elf-card-body {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 20rpx 12rpx 0;
}

.elf-avatar-bg {
  border-radius: 50%;
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.elf-avatar {
  width: 128rpx;
  height: 128rpx;
}

.elf-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2b45;
  display: block;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.elf-type {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #333333;
  background: #f7dcb3;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.elf-type-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.elf-stage {
  margin-top: 10rpx;
  display: flex;
  justify-content: center;
}

.elf-stage-text {
  display: inline-block;
  max-width: 140rpx;
  padding: 6rpx 14rpx;
  border-radius: 88rpx;
  border: 1rpx solid rgba(216, 93, 58, 0.55);
  background: rgba(255, 236, 214, 0.9);
  color: #c0492a;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

