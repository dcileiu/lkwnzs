<scroll-view class="page-container" scroll-y>
  <!-- Search Bar -->
  <view class="search-wrap">
    <input class="search-input" placeholder="搜索精灵、攻略、蛋..." bindtap="goToSearch" disabled="{{true}}" />
  </view>

  <!-- Quick Actions -->
  <view class="quick-actions">
    <view class="action-item" bindtap="navTo" data-url="/pages/hatch/index">
      <view class="icon-wrap">🥚</view>
      <text>孵蛋预测</text>
    </view>
    <view class="action-item" bindtap="navTo" data-url="/pages/pokedex/index">
      <view class="icon-wrap bg-green">✨</view>
      <text>精灵图鉴</text>
    </view>
    <view class="action-item" bindtap="navTo" data-url="/pages/collection/index">
      <view class="icon-wrap bg-pink">🎁</view>
      <text>宠物蛋集</text>
    </view>
    <view class="action-item" bindtap="navTo" data-url="/pages/guide/index">
      <view class="icon-wrap bg-blue">📖</view>
      <text>新手攻略</text>
    </view>
  </view>

  <!-- Popular Guides -->
  <view class="section">
    <view class="section-header">
      <text class="title">📈 热门攻略</text>
      <text class="more" bindtap="navTo" data-url="/pages/guide/index">查看更多 ></text>
    </view>
    <view class="guide-list">
      <block wx:for="{{hotArticles}}" wx:key="id">
        <view class="guide-item" bindtap="navTo" data-url="/pages/article/index?id={{item.id}}">
          <view class="guide-rank">{{index + 1}}</view>
          <view class="guide-info">
            <view class="guide-title">{{item.title}} <text class="tag-hot">HOT</text></view>
            <view class="guide-meta">{{item.authorName}} · {{item.views}}阅读</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- Popular Elves -->
  <view class="section">
    <view class="section-header">
      <text class="title">⭐ 热门精灵</text>
      <text class="more" bindtap="navTo" data-url="/pages/pokedex/index">全部图鉴 ></text>
    </view>
    <scroll-view class="elf-scroll" scroll-x>
      <block wx:for="{{hotElves}}" wx:key="id">
        <view class="elf-card" bindtap="goElfDetail" data-id="{{item.id}}">
          <view class="elf-avatar-bg">
            <image src="{{item.coverImage || item.avatar || '/assets/default-elf.png'}}" class="elf-avatar"></image>
          </view>
          <text class="elf-name">{{item.name}}</text>
          <view class="elf-tags">
            <block wx:for="{{item.elements}}" wx:key="*this">
              <text class="tag-element">{{item}}系</text>
            </block>
            <text class="tag-rarity">{{item.rarity}}</text>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</scroll-view>
