.page-container {
  width: 100%;
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.cover-badge-wrap {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  display: flex;
  gap: 15rpx;
}

.cover-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}

.cover-badge.hot { background: #ff4d4f; color: #fff; }
.cover-badge.normal { background: rgba(255,255,255,0.3); color: #fff; }

.cover-category {
  font-size: 22rpx;
  background: rgba(24,144,255,0.8);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}

.content-area {
  padding: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.article-title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1a1a;
  line-height: 1.6;
  margin-bottom: 25rpx;
}

.meta-row {
  margin-bottom: 30rpx;
}

.author-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 15rpx;
  min-width: 0;
}

.author-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #eee;
}

.author-text {
  flex: 1;
  min-width: 0;
}

.author-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.author-bio {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
  word-break: break-all;
}

.stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.stat {
  font-size: 24rpx;
  color: #bbb;
}

.action-bar {
  display: flex;
  gap: 0;
  margin-bottom: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.04);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-right: 1rpx solid #f0f0f0;
}

.action-btn:last-child {
  border-right: none;
}

.action-btn.active .action-icon,
.action-btn.active .action-label {
  color: #1890ff;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.action-label {
  font-size: 22rpx;
  color: #666;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 0 30rpx;
}

.article-body {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.body-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.9;
  word-break: break-all;
}

.author-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.author-card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.author-card-info {
  flex: 1;
  min-width: 0;
}

.author-card-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #eee;
}

.author-card-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.author-card-bio {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin: 8rpx 0;
  word-break: break-all;
}

.author-card-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
  font-size: 24rpx;
  color: #1890ff;
}

.comments-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

.comment-input-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 30rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
  padding: 10rpx 20rpx 10rpx 10rpx;
  box-sizing: border-box;
}

.my-avatar {
  width: 55rpx;
  height: 55rpx;
  border-radius: 50%;
  background: #eee;
}

.comment-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  padding: 10rpx;
}

.send-btn {
  font-size: 26rpx;
  color: #1890ff;
  padding: 5rpx 15rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 25rpx;
  padding-bottom: 25rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.comment-text {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
}

.empty-comments {
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 50rpx 0;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}
