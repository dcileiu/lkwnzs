.page-container {
  width: 100%;
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.content-area {
  padding: 30rpx;
  box-sizing: border-box;
}

.article-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.5;
}

.tag-row {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.tag-badge {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.tag-badge.hot { background: #ff4d4f; color: #fff; }
.tag-badge.category { background: #e6f4ff; color: #1677ff; }

.stats-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.stat {
  font-size: 24rpx;
  color: #7b879d;
}

.action-bar {
  margin-top: 22rpx;
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-bar.sticky {
  position: sticky;
  top: 0;
  z-index: 20;
  margin-top: 18rpx;
  background: linear-gradient(180deg, #f7fbff 0%, #eef5ff 100%);
  border: 2rpx solid #d6e4ff;
  box-shadow: 0 10rpx 24rpx rgba(67, 97, 238, 0.12);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-right: 1rpx solid #f0f0f0;
}

.action-bar.compact .action-btn {
  padding: 14rpx 0;
}

.action-btn:last-child { border-right: none; }
.action-btn.active .action-label,
.action-btn.active .action-icon { color: #1677ff; }

.action-icon { font-size: 34rpx; }
.action-label { font-size: 24rpx; color: #4b5563; }
.action-bar.sticky .action-label { color: #3f4f6b; font-weight: 600; }

.article-body {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.body-text {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.9;
  word-break: break-all;
}

.article-source {
  margin-top: 26rpx;
  text-align: right;
  color: #7b879d;
  font-size: 24rpx;
}

.comments-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 24rpx 0 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

.comment-input-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 30rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
  padding: 10rpx 20rpx 10rpx 10rpx;
  box-sizing: border-box;
}

.my-avatar,
.comment-avatar {
  width: 55rpx;
  height: 55rpx;
  border-radius: 50%;
  background: #eee;
}

.comment-input { flex: 1; font-size: 26rpx; padding: 10rpx; }
.send-btn { font-size: 26rpx; color: #1890ff; padding: 5rpx 15rpx; }

.comment-item { display: flex; gap: 20rpx; margin-bottom: 25rpx; padding-bottom: 25rpx; border-bottom: 1rpx solid #f5f5f5; }
.comment-body { flex: 1; min-width: 0; }
.comment-name { display: block; font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.comment-text { display: block; font-size: 28rpx; color: #555; line-height: 1.6; margin-bottom: 8rpx; word-break: break-all; }
.comment-time { font-size: 22rpx; color: #bbb; }
.empty-comments { text-align: center; color: #a1a1aa; font-size: 24rpx; padding: 20rpx 0 10rpx; }
.loading-state { min-height: 50vh; display: flex; align-items: center; justify-content: center; color: #999; }
