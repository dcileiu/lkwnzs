<view class="page-container">
  <view
    class="hero"
    >
    <image class="hero-bg" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/articles-bg.webp" mode="widthFix"></image>
    <view class="hero-overlay"></view>

    <view class="top-nav" style="padding-top: {{navTopPadding}}px;">
      <view class="nav-btn nav-back" bindtap="onBackTap">
        <image class="nav-back-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/bg-left.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">✦ 攻略详情 ✦</text>
    </view>

    <view class="hero-main" wx:if="{{article}}">
      <text class="hero-title">{{article.title}}</text>
      <view class="hero-tags">
        <text class="tag-hot" wx:if="{{article.isHot}}">🔥 HOT</text>
        <text class="tag-category" wx:if="{{article.category}}">{{article.category}}</text>
      </view>
      <view class="hero-meta">
        <view class="meta-item">
          <image class="meta-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/see.svg" mode="aspectFit"></image>
          <text>{{article.views || 0}}</text>
        </view>
        <view class="meta-item">
          <image class="meta-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/approve.svg" mode="aspectFit"></image>
          <text>{{article.likes || 0}}</text>
        </view>
        <view class="meta-item">
          <image class="meta-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/collect.svg" mode="aspectFit"></image>
          <text>{{article.favorites || article.likes || 0}}</text>
        </view>
        <view class="meta-item">
          <image class="meta-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/time.svg" mode="aspectFit"></image>
          <text>{{article.readingTime || 1}}分钟前阅读</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content-area" wx:if="{{article}}">
    <view id="actionBarAnchor" class="action-bar-anchor"></view>
    <view wx:if="{{isActionBarDocked}}" class="action-bar-placeholder"></view>
    <view class="action-bar {{isActionBarDocked ? 'is-docked' : ''}}" style="top: {{actionBarStickyTop}}px;">
      <view class="action-btn {{isLiked ? 'active' : ''}}" bindtap="toggleLike">
        <image
          class="action-icon-img"
          src="{{isLiked ? 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/approve-active.svg' : 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/approve.svg'}}"
          mode="aspectFit"
        ></image>
        <text class="action-label">点赞</text>
      </view>
      <view class="action-btn {{isFavorited ? 'active' : ''}}" bindtap="toggleFavorite">
        <image
          class="action-icon-img"
          src="{{isFavorited ? 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/collect-active.svg' : 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/collect-yello.svg'}}"
          mode="aspectFit"
        ></image>
        <text class="action-label">收藏</text>
      </view>
      <button class="action-btn action-share" open-type="share">
        <image class="action-icon-img" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/share.svg" mode="aspectFit"></image>
        <text class="action-label">分享</text>
      </button>
    </view>

    <view class="article-card">
      <rich-text class="body-rich-text" nodes="{{articleContentHtml}}"></rich-text>
      <view class="article-source" wx:if="{{article.sourceAuthor}}">
        <text>来源：{{article.sourceAuthor}}</text>
      </view>
    </view>

    <view class="comment-compose">
      <text class="comment-title">评论 ({{article.comments ? article.comments.length : 0}})</text>
      <view class="comment-input-wrap">
        <input
          class="comment-input"
          placeholder="写下你的评论..."
          value="{{commentInput}}"
          bindinput="onCommentInput"
          confirm-type="send"
          bindconfirm="submitComment"
        />
        <view class="send-btn" bindtap="submitComment">发送</view>
      </view>
    </view>

    <view class="comments-section" wx:if="{{article.comments && article.comments.length}}">
      <block wx:for="{{article.comments}}" wx:key="id">
        <view class="comment-item">
          <image class="comment-avatar" src="{{(item.user && item.user.avatar) || 'https://wallpaper.cdn.itianci.cn/imgs/avatar/default-avatar.webp'}}"></image>
          <view class="comment-body">
            <text class="comment-name">{{(item.user && item.user.nickname) || '洛克玩家'}}</text>
            <text class="comment-text">{{item.content}}</text>
            <text class="comment-time">{{item.createdAt}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view wx:if="{{!article}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>

