<view class="page-container">
  <view class="content-area" wx:if="{{article}}">
    <text class="article-title">{{article.title}}</text>

    <view class="tag-row">
      <text class="tag-badge hot" wx:if="{{article.isHot}}">🔥 HOT</text>
      <text class="tag-badge category" wx:if="{{article.category}}">{{article.category}}</text>
    </view>

    <view class="stats-row">
      <text class="stat">👁 {{article.views || 0}}</text>
      <text class="stat">☆ {{article.favorites || article.likes || 0}}</text>
      <text class="stat">⏱ {{article.readingTime || 1}}分钟阅读</text>
    </view>

    <view class="action-bar {{isActionBarSticky ? 'sticky compact' : ''}}">
      <view class="action-btn {{isLiked ? 'active' : ''}}" bindtap="toggleLike">
        <text class="action-icon" wx:if="{{!isActionBarSticky}}">{{isLiked ? '❤️' : '♡'}}</text>
        <text class="action-label">{{isLiked ? '已点赞' : '点赞'}}</text>
      </view>
      <view class="action-btn {{isFavorited ? 'active' : ''}}" bindtap="toggleFavorite">
        <text class="action-icon" wx:if="{{!isActionBarSticky}}">{{isFavorited ? '⭐' : '☆'}}</text>
        <text class="action-label">{{isFavorited ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-btn" open-type="share">
        <text class="action-icon" wx:if="{{!isActionBarSticky}}">↗</text>
        <text class="action-label">分享</text>
      </view>
    </view>

    <view class="article-body">
      <text class="body-text">{{article.content}}</text>
      <view class="article-source">来源于：{{article.source || article.sourceName || (article.author && article.author.name) || '未知'}}</view>
    </view>

    <view class="comments-section">
      <text class="section-title">💬 评论 ({{article.comments ? article.comments.length : 0}})</text>

      <view class="comment-input-row">
        <image class="my-avatar" src="https://roco.cdn.itianci.cn/imgs/avatar/default-avatar.jpg"></image>
        <input
          class="comment-input"
          placeholder="写下你的评论..."
          value="{{commentInput}}"
          bindinput="onCommentInput"
          confirm-type="send"
          bindconfirm="submitComment"
        />
        <view class="send-btn" bindtap="submitComment">发送</view>
      </view>

      <block wx:for="{{article.comments}}" wx:key="id">
        <view class="comment-item">
          <image class="comment-avatar" src="{{item.user.avatar || 'https://roco.cdn.itianci.cn/imgs/avatar/default-avatar.jpg'}}"></image>
          <view class="comment-body">
            <text class="comment-name">{{item.user.nickname}}</text>
            <text class="comment-text">{{item.content}}</text>
            <text class="comment-time">{{item.createdAt}}</text>
          </view>
        </view>
      </block>

      <view wx:if="{{!article.comments || article.comments.length === 0}}" class="empty-comments">
        还没有评论，快来抢沙发吧！
      </view>
    </view>
  </view>

  <view wx:if="{{!article}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
