.page-container {
  width: 100%;
  min-height: 100vh;
  background: #19335d;
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.45), rgba(30, 58, 100, 0.45)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  box-sizing: border-box;
}

.content-area {
  margin-top: 20rpx;
  padding: 0 18rpx 20rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  height: 460rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  max-width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0) 45%,
    rgba(25, 51, 93, 0.35) 65%,
    rgba(25, 51, 93, 0.75) 85%,
    #0f1f3e 100%
  );
}

.top-nav {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 0 200rpx 0 20rpx;
}

.nav-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(20, 43, 82, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 320rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #f9eec4;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 4rpx 14rpx rgba(8, 16, 36, 0.45);
  pointer-events: none;
}

.nav-back-icon {
  width: 58rpx;
  height: 58rpx;
}

.content-area {
  position: relative;
  top: -100rpx;
  padding: 0 20rpx 20rpx;
  box-sizing: border-box;
}

.tab-wrap {
  display: flex;
  gap: 12rpx;
  background: rgba(220, 231, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  backdrop-filter: blur(24rpx) saturate(120%);
  -webkit-backdrop-filter: blur(24rpx) saturate(120%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28),
    0 8rpx 18rpx rgba(8, 20, 48, 0.25);
  border-radius: 20rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: rgba(230, 239, 255, 0.9);
  font-weight: 600;
}

.tab-item.active {
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #eef5ff;
  text-shadow: 0 2rpx 8rpx rgba(7, 18, 44, 0.35);
}

.toolbar {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
}

.toolbar-btn {
  font-size: 22rpx;
  color: #f3f0e8;
  background: rgba(18, 38, 76, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
}

.empty-state {
  margin-top: 24rpx;
  padding: 80rpx 0;
  border-radius: 20rpx;
  background: linear-gradient(
    180deg,
    rgba(34, 64, 120, 0.98) 0%,
    rgba(42, 67, 117, 0.98) 100%
  );
  box-shadow:
    inset 0 0 0 1rpx rgba(193, 213, 255, 0.14),
    0 10rpx 22rpx rgba(9, 23, 55, 0.18);
  box-sizing: border-box;
  text-align: center;
  color: #f3f0e8;
  font-size: 26rpx;
}

.article-card,
.elf-card {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(248, 242, 229, 0.95);
  border: 1rpx solid rgba(223, 206, 175, 0.92);
}

.history-hot-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(
    180deg,
    rgba(34, 64, 120, 0.98) 0%,
    rgba(31, 57, 108, 0.98) 100%
  );
  box-shadow:
    inset 0 0 0 1rpx rgba(193, 213, 255, 0.14),
    0 10rpx 22rpx rgba(9, 23, 55, 0.18);
  box-sizing: border-box;
}

.history-hot-thumb {
  width: 200rpx;
  height: 144rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.history-hot-info {
  flex: 1;
  min-width: 0;
}

.history-hot-title {
  font-size: 26rpx;
  line-height: 1.46;
  font-weight: 700;
  color: #f8f3e6;
}

.history-hot-summary {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(217, 229, 255, 0.7);
}

.history-hot-stats {
  display: flex;
  gap: 18rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(217, 229, 255, 0.78);
}

.history-hot-stats-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.history-hot-stats-icon {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.thumb {
  width: 140rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.elf-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.content {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title {
  display: block;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.rarity {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  background: #fde7b4;
  color: #6f4c14;
}

.meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6f7788;
}

.line-clamp-1,
.line-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.line-clamp-1 {
  -webkit-line-clamp: 1;
}

.line-clamp-2 {
  -webkit-line-clamp: 2;
}
