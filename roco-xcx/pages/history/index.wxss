.page-container {
  width: 100%;
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.45), rgba(30, 58, 100, 0.45)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  box-sizing: border-box;
}

.hero {
  position: relative;
  height: 260rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0.25) 60%,
    rgba(25, 51, 93, 0.78) 100%
  );
}

.top-nav {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 0 200rpx 0 20rpx;
}

.nav-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(20, 43, 82, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 320rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #f9eec4;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 4rpx 14rpx rgba(8, 16, 36, 0.45);
  pointer-events: none;
}

.content-area {
  position: relative;
  top: -24rpx;
  padding: 0 20rpx 20rpx;
  box-sizing: border-box;
}

.tab-wrap {
  display: flex;
  gap: 12rpx;
  background: rgba(248, 240, 223, 0.85);
  border: 2rpx solid #d6c39f;
  border-radius: 20rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #5a4630;
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(180deg, #f5e6c8 0%, #ebd6ad 100%);
  color: #3f2f1d;
}

.toolbar {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
}

.toolbar-btn {
  font-size: 22rpx;
  color: #f3f0e8;
  background: rgba(18, 38, 76, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
}

.empty-state {
  margin-top: 24rpx;
  padding: 80rpx 0;
  border-radius: 20rpx;
  background: rgba(248, 242, 229, 0.9);
  text-align: center;
  color: #7b6a4f;
  font-size: 26rpx;
}

.article-card,
.elf-card {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(248, 242, 229, 0.95);
  border: 1rpx solid rgba(223, 206, 175, 0.92);
}

.thumb {
  width: 140rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.elf-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.content {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title {
  display: block;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.rarity {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  background: #fde7b4;
  color: #6f4c14;
}

.meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6f7788;
}
