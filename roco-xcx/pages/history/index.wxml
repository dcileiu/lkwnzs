<view class="page-container">
  <view class="hero">
    <image class="hero-bg" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/articles-bg.webp" mode="aspectFill"></image>
    <view class="hero-overlay"></view>
    <view class="top-nav" style="padding-top: {{navTopPadding}}px;">
      <view class="nav-btn nav-back" bindtap="onBackTap">‹</view>
      <text class="nav-title">✦ 浏览历史 ✦</text>
    </view>
  </view>

  <view class="content-area">
    <view class="tab-wrap">
      <view class="tab-item {{activeTab === 'article' ? 'active' : ''}}" data-tab="article" bindtap="switchTab">
        文章历史
      </view>
      <view class="tab-item {{activeTab === 'elf' ? 'active' : ''}}" data-tab="elf" bindtap="switchTab">
        精灵历史
      </view>
    </view>

    <view class="toolbar">
      <view class="toolbar-btn" bindtap="clearCurrentTab">清空当前</view>
    </view>

    <view wx:if="{{activeTab === 'article'}}">
      <view wx:if="{{articleItems.length === 0}}" class="empty-state">暂无文章浏览记录</view>
      <block wx:for="{{articleItems}}" wx:key="id">
        <view class="article-card" data-id="{{item.targetId}}" bindtap="openArticle">
          <image class="thumb" src="{{item.thumbnail || 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/default-article.png'}}" mode="aspectFill"></image>
          <view class="content">
            <text class="title">{{item.title}}</text>
            <text class="meta">浏览 {{item.viewCount}} 次 · {{item.viewedAt}}</text>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{activeTab === 'elf'}}">
      <view wx:if="{{elfItems.length === 0}}" class="empty-state">暂无精灵浏览记录</view>
      <block wx:for="{{elfItems}}" wx:key="id">
        <view class="elf-card" data-id="{{item.targetId}}" bindtap="openElf">
          <image class="elf-avatar" src="{{item.avatar || 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/default-elf.png'}}" mode="aspectFill"></image>
          <view class="content">
            <view class="name-row">
              <text class="title">{{item.name}}</text>
              <text class="rarity" wx:if="{{item.rarity}}">{{item.rarity}}</text>
            </view>
            <text class="meta">{{item.element || '未知属性'}} · {{item.group || '未分组'}}</text>
            <text class="meta">浏览 {{item.viewCount}} 次 · {{item.viewedAt}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
