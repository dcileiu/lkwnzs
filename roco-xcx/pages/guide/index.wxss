.page-container {
  width: 100%;
  padding: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background: #1f3b64;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  position: relative;
  min-height: 332rpx;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  display: block;
  width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(11, 38, 86, 0) 0%, rgba(31, 59, 100, 0.4) 70%, #1f3b64 100%);
  pointer-events: none;
}

.hero-content {
  position: absolute;
  inset: 0;
  padding: 220rpx 20rpx 0;
  z-index: 2;
  box-sizing: border-box;
}

.search-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
  width: 400rpx;
  height: 74rpx;
  padding: 0 28rpx;
  border-radius: 40rpx;
  background: linear-gradient(
    180deg,
    rgba(107, 144, 170, 0.58) 0%,
    rgba(76, 117, 150, 0.42) 52%,
    rgba(62, 102, 138, 0.5) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    inset 0 -8rpx 16rpx rgba(21, 45, 78, 0.16),
    0 10rpx 24rpx rgba(8, 22, 49, 0.22);
  backdrop-filter: blur(14px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff0c9;
}

.guide-main {
  position: relative;
  z-index: 3;
  margin-top: -100rpx;
  padding: 0 20rpx;
}

.tabs-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.tabs {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 20rpx;
}

.tab-item {
  position: relative;
  min-width: 116rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 188rpx;
  background: rgba(34, 61, 113, 0.82);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
}

.tab-item.active {
  box-shadow: 0 8rpx 18rpx rgba(16, 22, 62, 0.28);
}

.tab-active-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.tab-label {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(240, 246, 255, 0.92);
}

.tab-item.active .tab-label {
  color: #fff3d4;
}

.featured-wrap {
  margin-top: 20rpx;
}

.featured-swiper {
  height: 268rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.featured-card {
  position: relative;
  height: 268rpx;
  padding: 18rpx 20rpx 22rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 14rpx 28rpx rgba(8, 24, 54, 0.28);
}

.featured-card-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.featured-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(16, 28, 74, 0.22) 0%, rgba(19, 45, 96, 0.08) 22%, rgba(21, 58, 118, 0.12) 48%, rgba(13, 33, 71, 0.28) 100%);
}

.featured-head {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.featured-rank {
  min-width: 76rpx;
  height: 44rpx;
  padding: 0 12rpx;
  border-radius: 12rpx 12rpx 12rpx 0;
  background: linear-gradient(180deg, #9566ff 0%, #7a4ce2 100%);
  color: #fff4dc;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  box-shadow: 0 6rpx 14rpx rgba(63, 42, 149, 0.28);
}

.featured-hot {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #ff6a4f;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.featured-body {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: calc(100% - 40rpx);
}

.featured-category {
  align-self: flex-start;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(248, 228, 177, 0.14);
  border: 1rpx solid rgba(255, 234, 191, 0.28);
  color: #ffeec8;
  font-size: 22rpx;
  line-height: 1.2;
}

.featured-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #f6f2e8;
}

.featured-summary {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(222, 234, 255, 0.8);
}

.featured-meta {
  margin-top: auto;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
}

.featured-author {
  max-width: 180rpx;
  font-size: 22rpx;
  color: #f0d9ab;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.featured-stats {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx 16rpx;
  font-size: 20rpx;
  color: rgba(228, 237, 255, 0.86);
}

.featured-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.featured-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(244, 229, 194, 0.35);
}

.featured-dot.active {
  width: 24rpx;
  border-radius: 999rpx;
  background: #f4e5c2;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0 18rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #f7eedb;
}

.section-more {
  font-size: 24rpx;
  color: rgba(224, 233, 255, 0.86);
  flex-shrink: 0;
}

.hot-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(34, 64, 120, 0.98) 0%, rgba(31, 57, 108, 0.98) 100%);
  box-shadow:
    inset 0 0 0 1rpx rgba(193, 213, 255, 0.14),
    0 10rpx 22rpx rgba(9, 23, 55, 0.18);
  box-sizing: border-box;
}

.hot-rank {
  position: absolute;
  top: -8rpx;
  left: 14rpx;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 8rpx;
  border-radius: 12rpx 12rpx 12rpx 0;
  background: linear-gradient(180deg, #ffbf66 0%, #ff8c3a 100%);
  color: #fffaf1;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
}

.hot-thumb {
  width: 178rpx;
  height: 118rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.hot-info {
  flex: 1;
  min-width: 0;
}

.hot-title {
  font-size: 30rpx;
  line-height: 1.46;
  font-weight: 700;
  color: #f8f3e6;
}

.hot-summary {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(217, 229, 255, 0.7);
}

.hot-stats {
  display: flex;
  gap: 18rpx;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(217, 229, 255, 0.78);
}

.hot-arrow {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(244, 231, 207, 0.9);
  font-size: 34rpx;
  line-height: 42rpx;
  text-align: center;
  flex-shrink: 0;
}

.line-clamp-1,
.line-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.line-clamp-1 {
  -webkit-line-clamp: 1;
}

.line-clamp-2 {
  -webkit-line-clamp: 2;
}

.empty-state {
  padding: 140rpx 0 100rpx;
  text-align: center;
  font-size: 28rpx;
  color: rgba(224, 233, 255, 0.72);
}
