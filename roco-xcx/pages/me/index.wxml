<scroll-view class="page-container" scroll-y enable-flex>
  <view class="hero">
    <image class="hero-bg" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/me.webp" mode="widthFix"></image>
    <view class="hero-overlay"></view>
  </view>

  <view class="me-main">
    <view class="profile-card">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar" src="{{profile.avatar || 'https://wallpaper.cdn.itianci.cn/imgs/avatar/default-avatar.webp'}}" mode="aspectFill"></image>
      </button>
      <view class="profile-info">
        <view class="nickname-row">
            <text class="nickname">{{profile.nickname || '洛克训练师'}}</text>
            <text class="edit-btn" bindtap="editNickname">修改名称</text>
        </view>
        <view class="profile-meta-row">
          <text class="desc">小洛克，欢迎回来！</text>
          <text class="uid">UID: {{uid || '未登录'}}</text>
        </view>
      </view>
    </view>

    <view class="menu-card">
      <block wx:for="{{menus}}" wx:key="key">
        <button
          wx:if="{{item.key === 'share'}}"
          class="menu-item menu-share-btn {{index === 0 ? 'first' : ''}} {{index === menus.length - 1 ? 'last' : ''}}"
          open-type="share"
        >
          <view class="menu-text-wrap">
            <view class="menu-title-row">
              <text class="menu-title">{{item.title}}</text>
            </view>
            <text class="menu-desc">{{item.desc}}</text>
          </view>
            <image class="menu-arrow-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/bg-left.svg" mode="aspectFit"></image>
        </button>
        <view
          wx:else
          class="menu-item {{index === 0 ? 'first' : ''}} {{index === menus.length - 1 ? 'last' : ''}}"
          data-key="{{item.key}}"
          bindtap="onMenuTap"
        >
          <view class="menu-text-wrap">
            <view class="menu-title-row">
              <text class="menu-title">{{item.title}}</text>
              <text wx:if="{{item.key === 'like'}}" class="menu-count">{{likeCount}}</text>
              <text wx:if="{{item.key === 'favorite'}}" class="menu-count">{{favoriteCount}}</text>
              <text wx:if="{{item.key === 'history'}}" class="menu-count">{{historyCount}}</text>
            </view>
            <text class="menu-desc">{{item.desc}}</text>
          </view>
            <image class="menu-arrow-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/bg-left.svg" mode="aspectFit"></image>
        </view>
      </block>
    </view>

  </view>

  <view wx:if="{{showNicknameDialog}}" class="nickname-dialog-mask" catchtouchmove="true">
    <view class="nickname-dialog" catchtap="noop">
      <view class="nickname-dialog-title">修改名称</view>
      <input
        class="nickname-dialog-input"
        value="{{nicknameDraft}}"
        placeholder="请输入新的用户名"
        maxlength="20"
        focus
        bindfocus="onNicknameFocus"
        bindinput="onNicknameInput"
      />
      <view wx:if="{{showWechatSuggestion && wechatNickname}}" class="nickname-suggestion-wrap">
        <text class="nickname-suggestion-label">微信昵称候选</text>
        <view class="nickname-suggestion-chip" bindtap="fillWechatNickname">{{wechatNickname}}</view>
      </view>
      <view class="nickname-dialog-actions">
        <view class="nickname-dialog-btn cancel" bindtap="closeNicknameDialog">取消</view>
        <view class="nickname-dialog-btn confirm" bindtap="submitNickname">确定</view>
      </view>
    </view>
  </view>
</scroll-view>

