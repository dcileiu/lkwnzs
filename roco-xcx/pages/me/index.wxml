<view class="page-container">
  <view class="profile-card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{profile.avatar || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
    </button>
    <view class="profile-info">
      <view class="nickname-row">
        <text class="nickname">{{profile.nickname || '洛克训练师'}}</text>
        <view class="nickname-actions">
          <text class="edit-btn" bindtap="editNickname">修改名称</text>
          <text class="wx-btn" bindtap="useWechatNickname">微信昵称</text>
        </view>
      </view>
      <text class="desc">欢迎回来，看看你的文章互动数据</text>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card" bindtap="openLikedArticles">
      <text class="stat-label">文章点赞</text>
      <text class="stat-value">{{likeCount}}</text>
      <text class="stat-link">查看我点赞的文章 ></text>
    </view>

    <view class="stat-card" bindtap="openFavoriteArticles">
      <text class="stat-label">文章收藏</text>
      <text class="stat-value">{{favoriteCount}}</text>
      <text class="stat-link">查看我收藏的文章 ></text>
    </view>
  </view>
</view>
