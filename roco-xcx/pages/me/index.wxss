.page-container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.avatar-btn {
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.profile-info {
  flex: 1;
}

.nickname-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.nickname {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.nickname-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.edit-btn,
.wx-btn {
  font-size: 22rpx;
  color: #4f74ff;
  background: #eef3ff;
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
}

.desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b879d;
}

.stats-grid {
  margin-top: 24rpx;
  display: grid;
  gap: 18rpx;
}

.stat-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-label {
  display: block;
  color: #7b879d;
  font-size: 24rpx;
}

.stat-value {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #1f2937;
}

.stat-link {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4f74ff;
}
