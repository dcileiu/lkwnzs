.page-container {
  width: 100%;
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  position: relative;
  min-height: 320rpx;
  overflow: hidden;
}

.hero-bg {
  display: block;
  width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0.12) 55%,
    rgba(25, 51, 93, 0.55) 82%,
    #19335d 100%
  );
}

.me-main {
  position: relative;
  z-index: 3;
  margin-top: -240rpx;
  padding: 0 20rpx;
}

.profile-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
  overflow: hidden;
}

.profile-card::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: transparent;
}

.avatar-btn {
  width: 114rpx !important;
  height: 114rpx;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 12rpx rgba(7, 18, 44, 0.4);
}

.profile-info {
  position: relative;
  flex: 1;
  min-width: 0;
  z-index: 1;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  margin-right: auto;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(7, 18, 44, 0.45);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.uid {
  flex-shrink: 0;
  font-size: 22rpx;
  color: rgba(232, 240, 255, 0.78);
}

.edit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  line-height: 1;
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.desc {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: rgba(232, 240, 255, 0.82);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-meta-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.menu-card {
  margin-top: 18rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24),
    0 10rpx 20rpx rgba(8, 22, 49, 0.2);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 22rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.18);
}

.menu-item.last {
  border-bottom: none;
}

button.menu-share-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  margin: 0;
  padding: 22rpx 22rpx;
  border: none;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 0;
  background: transparent;
  line-height: normal;
  font-weight: inherit;
  color: inherit;
  text-align: left;
  box-sizing: border-box;
}

button.menu-share-btn::after {
  border: none;
}

.menu-text-wrap {
  flex: 1;
  min-width: 0;
}

.menu-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-title {
  display: inline-block;
  font-size: 30rpx;
  font-weight: 600;
  color: #edf4ff;
}

.menu-count {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #1f3b64;
  background: #f4d9a5;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.menu-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(201, 220, 255, 0.74);
}

.menu-arrow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 34rpx;
  color: rgba(233, 243, 255, 0.86);
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  flex-shrink: 0;
}

.nickname-dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(6, 18, 44, 0.55);
  padding: 0 40rpx;
  box-sizing: border-box;
}

.nickname-dialog {
  width: 100%;
  max-width: 620rpx;
  border-radius: 20rpx;
  background: rgba(220, 231, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  backdrop-filter: blur(24rpx) saturate(120%);
  -webkit-backdrop-filter: blur(24rpx) saturate(120%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28),
    0 20rpx 40rpx rgba(8, 20, 48, 0.35);
  overflow: hidden;
}

.nickname-dialog-title {
  padding: 30rpx 32rpx 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #eef5ff;
  text-shadow: 0 2rpx 8rpx rgba(7, 18, 44, 0.38);
  text-align: center;
}

.nickname-dialog-input {
  margin: 0 32rpx;
  height: 82rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  font-size: 30rpx;
  color: #eef5ff;
  box-sizing: border-box;
}

.nickname-suggestion-wrap {
  margin: 14rpx 32rpx 0;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.nickname-suggestion-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: rgba(229, 239, 255, 0.82);
}

.nickname-suggestion-chip {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(170, 205, 255, 0.24);
  border: 1rpx solid rgba(188, 219, 255, 0.45);
  color: #e8f2ff;
  font-size: 24rpx;
}

.nickname-dialog-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-top: 22rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.nickname-dialog-btn {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 32rpx;
}

.nickname-dialog-btn.cancel {
  color: rgba(230, 239, 255, 0.9);
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.nickname-dialog-btn.confirm {
  color: #a9c8ff;
  font-weight: 700;
}
