<view class="page-container">
  <view class="page-header">
    <text class="page-title">孵蛋预测</text>
    <text class="page-sub">输入固定的身高和体重值，系统会自动匹配可能的精灵</text>
  </view>

  <view class="card form-card">
    <view class="input-item">
      <view class="picker-label">身高</view>
      <input
        class="input-field"
        type="digit"
        placeholder="请输入固定身高值"
        value="{{heightValue}}"
        bindinput="onHeightInput"
        confirm-type="next"
      />
    </view>

    <view class="input-item border-none">
      <view class="picker-label">体重</view>
      <input
        class="input-field"
        type="digit"
        placeholder="请输入固定体重值"
        value="{{weightValue}}"
        bindinput="onWeightInput"
        confirm-type="done"
      />
    </view>

    <view class="form-actions">
      <button class="btn-predict" bindtap="predict">开始预测</button>
    </view>
  </view>

  <view wx:if="{{results.length}}" class="card">
    <view class="results-header">
      <text>匹配结果</text>
      <text>共 {{results.length}} 种可能</text>
    </view>

    <view class="results-list">
      <block wx:for="{{results}}" wx:key="elfId">
        <view class="result-item" bindtap="goElfDetail" data-id="{{item.elfId}}">
          <view class="elf-avatar-bg">
            <image
              class="elf-avatar-small"
              src="{{item.elfCoverImage || '/assets/default-elf.png'}}"
              mode="aspectFit"
            ></image>
          </view>

          <view class="elf-info">
            <text class="elf-name">{{item.elfName}}</text>
            <text class="elf-range" wx:if="{{item.elfHeight || item.elfWeight}}">身高 {{item.elfHeight || "-"}} / 体重 {{item.elfWeight || "-"}}</text>
            <view class="elf-meta">
              <block wx:for="{{item.elfElements}}" wx:key="*this">
                <text class="tag-element">{{item}}系</text>
              </block>
              <text class="tag-rarity">{{item.elfRarity}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view wx:if="{{searched && !results.length}}" class="card empty-card">
    <text class="empty-title">没有匹配到精灵</text>
    <text class="empty-sub">可以换一个更精确的身高或体重值再试试</text>
  </view>
</view>
