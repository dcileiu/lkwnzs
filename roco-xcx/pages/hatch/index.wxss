.page-container {
  width: 100%;
  padding: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a73e8;
  margin-bottom: 10rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.input-item.border-none {
  border-bottom: none;
  padding-bottom: 0;
}

.picker-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.input-field {
  width: 100%;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #333;
  min-height: 88rpx;
}

.form-actions {
  display: flex;
  justify-content: center;
  padding-top: 12rpx;
}

.btn-predict {
  background: #1890ff;
  color: #fff;
  width: 80%;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.preview-card {
  min-height: 520rpx;
}

.preview-card-idle {
  min-height: 320rpx;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b879d;
  line-height: 1.6;
}

.preview-stage {
  min-height: 420rpx;
  background: linear-gradient(180deg, #f6f9ff 0%, #eef5ff 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  box-sizing: border-box;
}

.preview-egg-image {
  width: 100%;
  height: 360rpx;
}

.preview-empty {
  min-height: 420rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.preview-empty-idle {
  min-height: 220rpx;
  padding: 32rpx 40rpx;
}

.preview-empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.preview-empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b879d;
  line-height: 1.6;
}

.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.results-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.results-count {
  font-size: 24rpx;
  color: #7b879d;
}

.top-result-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #eef6ff 0%, #f6fbff 100%);
  border-radius: 16rpx;
}

.top-result-label {
  font-size: 20rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.top-result-name {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.top-result-prob {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 16rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

.result-item.active {
  border: 2rpx solid #1890ff;
  background: #eef6ff;
}

.elf-avatar-bg {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  padding: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.elf-avatar-small {
  width: 100%;
  height: 100%;
}

.elf-info {
  flex: 1;
  min-width: 0;
}

.elf-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.elf-range {
  margin-top: 6rpx;
  display: block;
  font-size: 20rpx;
  color: #7b879d;
}

.elf-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tag-top {
  font-size: 20rpx;
  color: #ff8a00;
  background: rgba(255, 138, 0, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
}

.tag-rarity {
  font-size: 20rpx;
  background: #e6f7ff;
  color: #1890ff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.tag-element {
  font-size: 20rpx;
  color: #999;
}

.result-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.result-prob {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}

.result-prob-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #7b879d;
}

.result-detail-link {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #1890ff;
}
