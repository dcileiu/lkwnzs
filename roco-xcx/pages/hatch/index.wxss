.page-container {
  width: 100%;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  box-sizing: border-box;
  background-color: #f5f7fb;
}

.page-header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a73e8;
}

.page-sub {
  font-size: 24rpx;
  line-height: 1.6;
  color: #666;
}

.card {
  margin-bottom: 30rpx;
  padding: 30rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.input-item.border-none {
  padding-bottom: 0;
  border-bottom: none;
}

.picker-label {
  margin-bottom: 15rpx;
  font-size: 26rpx;
  color: #333;
}

.input-field {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #f8f9fa;
  color: #333;
  font-size: 28rpx;
}

.form-actions {
  display: flex;
  justify-content: center;
  padding-top: 12rpx;
}

.btn-predict {
  width: 80%;
  padding: 10rpx 0;
  border-radius: 40rpx;
  background: #1890ff;
  color: #fff;
  font-size: 32rpx;
}

.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.results-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.results-count {
  font-size: 24rpx;
  color: #7b879d;
}

.top-result-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #eef6ff 0%, #f6fbff 100%);
}

.top-result-label {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(24, 144, 255, 0.12);
  color: #1890ff;
  font-size: 20rpx;
}

.top-result-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #333;
  font-size: 26rpx;
  font-weight: bold;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-result-prob {
  color: #1890ff;
  font-size: 28rpx;
  font-weight: bold;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f9fa;
}

.result-item.active {
  border: 2rpx solid #1890ff;
  background: #eef6ff;
}

.elf-avatar-bg {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  padding: 10rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: #fff;
  flex-shrink: 0;
}

.elf-avatar-small {
  width: 100%;
  height: 100%;
}

.elf-info {
  flex: 1;
  min-width: 0;
}

.elf-name {
  display: block;
  overflow: hidden;
  color: #333;
  font-size: 30rpx;
  font-weight: bold;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.elf-range {
  display: block;
  margin-top: 6rpx;
  color: #7b879d;
  font-size: 20rpx;
}

.elf-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tag-top {
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 138, 0, 0.12);
  color: #ff8a00;
  font-size: 20rpx;
}

.tag-rarity {
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: #e6f7ff;
  color: #1890ff;
  font-size: 20rpx;
}

.tag-element {
  color: #999;
  font-size: 20rpx;
}

.result-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.result-prob {
  color: #1890ff;
  font-size: 32rpx;
  font-weight: bold;
}

.result-prob-label {
  margin-top: 4rpx;
  color: #7b879d;
  font-size: 20rpx;
}

.result-detail-link {
  margin-top: 14rpx;
  color: #1890ff;
  font-size: 22rpx;
}

.empty-results-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
  text-align: center;
}

.empty-results-title {
  display: block;
  color: #333;
  font-size: 30rpx;
  font-weight: bold;
}

.empty-results-sub {
  display: block;
  margin-top: 12rpx;
  color: #7b879d;
  font-size: 24rpx;
  line-height: 1.6;
}
