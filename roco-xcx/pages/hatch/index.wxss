.page-container {
  width: 100%;
  padding: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  position: relative;
  width: 100%;
  height: 500rpx;
  background: #183158;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0) 45%,
    rgba(25, 51, 93, 0.35) 65%,
    rgba(25, 51, 93, 0.75) 85%,
    #19335d 100%
  );
}

.hatch-main {
  position: relative;
  z-index: 3;
  margin-top: -100rpx;
  padding: 0 24rpx;
}

.card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7e6cb 0%, #f1dab8 100%);
  border: 2rpx solid rgba(255, 234, 196, 0.85);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65),
    0 14rpx 28rpx rgba(8, 24, 54, 0.28);
  box-sizing: border-box;
}

/* ---------- Form ---------- */

.form-card {
  padding: 30rpx 28rpx 36rpx;
}

.form-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.form-cell {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.form-divider {
  width: 2rpx;
  background: rgba(106, 72, 30, 0.18);
  align-self: stretch;
  margin: 6rpx 0 14rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 28rpx;
  color: #4d3216;
  font-weight: 700;
}

.form-label-icon {
  font-size: 30rpx;
}

.form-label-text {
  flex: 1;
}

.form-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #8a6a3b;
}

.form-input {
  margin-top: 16rpx;
  height: 70rpx;
  font-size: 28rpx;
  color: #2c1d0a;
  border-bottom: 2rpx solid rgba(106, 72, 30, 0.2);
}

.form-input-placeholder {
  color: rgba(106, 72, 30, 0.45);
  font-size: 26rpx;
}

.predict-btn-wrap {
  margin: 32rpx auto 0;
  width: 80%;
  height: 96rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background-image: url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/hatche-btn.webp");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-position: center;
  box-shadow: 0 12rpx 22rpx rgba(40, 30, 110, 0.32);
}

.predict-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  height: 100%;
}

.predict-btn-text {
  color: #fff5d8;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 6rpx rgba(36, 22, 86, 0.45);
}

/* ---------- Results ---------- */

.results-card {
  padding: 28rpx 22rpx 22rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding: 0 4rpx;
  margin-bottom: 18rpx;
}

.results-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.results-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #4d3216;
}

.results-title-deco {
  color: #d39e3a;
  font-size: 24rpx;
}

.results-count {
  font-size: 24rpx;
  color: #8a6a3b;
  flex-shrink: 0;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.58) 0%,
    rgba(255, 255, 255, 0.38) 100%
  );
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.58),
    0 8rpx 20rpx rgba(15, 27, 56, 0.18);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  box-sizing: border-box;
}

.result-item.is-top {
  border-color: #8a6cff;
  background: linear-gradient(
    180deg,
    rgba(241, 237, 255, 0.7) 0%,
    rgba(255, 255, 255, 0.45) 100%
  );
  box-shadow:
    inset 0 0 0 2rpx rgba(138, 108, 255, 0.18),
    0 8rpx 18rpx rgba(91, 70, 200, 0.18);
}

.result-avatar {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f5ebd6;
  border: 2rpx solid rgba(159, 134, 87, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.result-avatar-img {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  z-index: 2;
}

.result-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.result-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c2236;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-range {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a8597;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-tags {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
  width: 100%;
}

.tag-top {
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #ffd16b 0%, #ff9d3a 100%);
  color: #5a2c00;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 6rpx rgba(255, 140, 0, 0.28);
}

.tag-element {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  background: #3f5a8a;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.5;
}

.tag-rarity {
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(138, 108, 255, 0.6);
  background: rgba(138, 108, 255, 0.1);
  color: #6a4ad6;
  font-size: 20rpx;
  font-weight: 600;
}

.result-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
  min-width: 130rpx;
}

.result-prob {
  font-size: 36rpx;
  font-weight: 800;
  color: #2c2236;
  line-height: 1.1;
}

.result-prob.is-top {
  color: #6a4ad6;
}

.result-detail-link {
  position: absolute;
  right: 18rpx;
  bottom: 20rpx;
  margin-left: auto;
  font-size: 22rpx;
  color: #5b80c9;
}

/* ---------- Empty ---------- */

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
  text-align: center;
}

.empty-title {
  display: block;
  color: #4d3216;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  color: #8a6a3b;
  font-size: 24rpx;
  line-height: 1.6;
}
