.page-container {
  width: 100%;
  padding: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a73e8;
  margin-bottom: 10rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #666;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  box-sizing: border-box;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.input-item.border-none {
  border-bottom: none;
  padding-bottom: 0;
}

.picker-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.input-field {
  width: 100%;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #333;
  min-height: 88rpx;
}

.form-actions {
  display: flex;
  justify-content: center;
  padding-top: 12rpx;
}

.btn-predict {
  background: #1890ff;
  color: #fff;
  width: 80%;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.results-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 16rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

.empty-card {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b879d;
}

.elf-avatar-bg {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  padding: 10rpx;
  margin-right: 20rpx;
}

.elf-avatar-small {
  width: 100%;
  height: 100%;
}

.elf-info {
  flex: 1;
  min-width: 0;
}

.elf-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}


.elf-range {
  margin-top: 6rpx;
  display: block;
  font-size: 20rpx;
  color: #7b879d;
}

.elf-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 8rpx;
}

.tag-rarity {
  font-size: 20rpx;
  background: #e6f7ff;
  color: #1890ff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.tag-element {
  font-size: 20rpx;
  color: #999;
}
