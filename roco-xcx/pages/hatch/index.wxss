.page-container {
  width: 100%;
  padding: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a73e8;
  margin-bottom: 10rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #666;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  box-sizing: border-box;
}

.picker-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.picker-item.border-none {
  border-bottom: none;
  padding-bottom: 0;
}

.picker-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.placeholder {
  color: #999;
}

.arrow {
  color: #ccc;
  font-size: 24rpx;
}

.visual-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.egg-visual-bg {
  width: 200rpx;
  height: 200rpx;
  background: #eef2ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.egg-visual {
  width: 120rpx;
  height: 120rpx;
}

.btn-predict {
  background: #1890ff;
  color: #fff;
  width: 80%;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.results-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 16rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

.elf-avatar-bg {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  padding: 10rpx;
  margin-right: 20rpx;
}

.elf-avatar-small {
  width: 100%;
  height: 100%;
}

.elf-info {
  flex: 1;
  min-width: 0;
}

.elf-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.elf-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 8rpx;
}

.tag-rarity {
  font-size: 20rpx;
  background: #e6f7ff;
  color: #1890ff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.tag-element {
  font-size: 20rpx;
  color: #999;
}

.probability {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.prob-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.prob-label {
  font-size: 20rpx;
  color: #999;
}
