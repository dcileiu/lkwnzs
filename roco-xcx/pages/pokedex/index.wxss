.page-container {
  min-height: 100vh;
  background-color: #f5f7fb;
  box-sizing: border-box;
}

.page-inner {
  width: 100%;
  padding: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  box-sizing: border-box;
}

.pokedex-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #1890ff;
  color: #fff;
  padding: 26rpx 0;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.82;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.28);
}

.sticky-filter-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #f5f7fb;
  padding: 8rpx 0 18rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 28rpx;
  margin-bottom: 16rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 10rpx;
}

.element-tabs {
  width: 100%;
  white-space: nowrap;
}

.tabs-wrap {
  display: inline-flex;
  align-items: center;
  padding-right: 20rpx;
}

.tab-item {
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border-radius: 30rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.tab-item.active {
  background: #1890ff;
  color: #fff;
}

.elf-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
  padding-top: 4rpx;
}

.elf-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
  min-width: 0;
  box-sizing: border-box;
}

.elf-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  background: #f0f4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
  overflow: hidden;
}

.elf-avatar {
  width: 90rpx;
  height: 90rpx;
}

.elf-avatar-fallback {
  font-size: 42rpx;
  font-weight: bold;
  color: #93a9e8;
}

.elf-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  width: 100%;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.elf-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  align-items: center;
  width: 100%;
}

.tag-element {
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tag-rarity {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #e6f7ff;
  color: #1890ff;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tag-rarity.SSR { color: #eb2f96; background: #fff0f6; }
.tag-rarity.SR { color: #722ed1; background: #f9f0ff; }
.tag-rarity.UR { color: #fa8c16; background: #fff7e6; }

.empty-state {
  text-align: center;
  padding: 120rpx 0 80rpx;
  color: #999;
  font-size: 28rpx;
}

.load-more-tip {
  text-align: center;
  color: #9aa3b2;
  font-size: 24rpx;
  padding: 24rpx 0 10rpx;
}
