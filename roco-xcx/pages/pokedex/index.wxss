.page-container {
  width: 100%;
  padding: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://roco.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ---------- Hero ---------- */

.hero {
  position: relative;
  min-height: 332rpx;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  display: block;
  width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0) 45%,
    rgba(25, 51, 93, 0.35) 65%,
    rgba(25, 51, 93, 0.75) 85%,
    #19335d 100%
  );
}

.hero-content {
  position: absolute;
  inset: 0;
  padding: 220rpx 20rpx 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.search-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 74rpx;
  padding: 0 28rpx;
  border-radius: 40rpx;
  background: linear-gradient(
    180deg,
    rgba(107, 144, 170, 0.58) 0%,
    rgba(76, 117, 150, 0.42) 52%,
    rgba(62, 102, 138, 0.5) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    inset 0 -8rpx 16rpx rgba(21, 45, 78, 0.16),
    0 10rpx 24rpx rgba(8, 22, 49, 0.22);
  backdrop-filter: blur(14px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  font-weight: 500;
  color: #fff0c9;
}

.pokedex-stats {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 74rpx;
  padding: 0 22rpx;
  border-radius: 40rpx;
  background: rgba(13, 28, 56, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12),
    0 6rpx 16rpx rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  color: #fff;
  box-sizing: border-box;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 50rpx;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #fff;
  letter-spacing: 1rpx;
}

.stat-label {
  margin-top: 2rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.72);
}

.stat-divider {
  width: 1rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.22);
}

/* ---------- Pokedex Main ---------- */

.pokedex-main {
  position: relative;
  z-index: 3;
  margin-top: -40rpx;
  padding: 0 18rpx 20rpx;
  box-sizing: border-box;
}

/* ---------- Tabs ---------- */

.tabs-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
  padding: 4rpx 0 8rpx;
}

.tabs {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding-right: 20rpx;
}

.tab-item {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 116rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 188rpx;
  background: rgba(34, 61, 113, 0.6);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  overflow: hidden;
  box-sizing: border-box;
  flex-shrink: 0;
}

.tab-item.active {
  background: rgba(34, 61, 113, 0.82);
  box-shadow: 0 8rpx 18rpx rgba(16, 22, 62, 0.28);
}

.tab-active-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.tab-icon {
  position: relative;
  z-index: 1;
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.tab-label {
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(240, 246, 255, 0.92);
  line-height: 1;
}

.tab-item.active .tab-label {
  color: #fff3d4;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(20, 30, 80, 0.5);
}

/* ---------- Elf Grid ---------- */

.elf-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  padding-top: 6rpx;
}

.elf-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx 18rpx;
  border-radius: 16rpx;
  background-image: url("https://roco.cdn.itianci.cn/imgs/miniapp/elf-card.webp");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  box-sizing: border-box;
  min-height: 280rpx;
  overflow: hidden;
}

.elf-no {
  position: absolute;
  top: 16rpx;
  right: 18rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #b08a4d;
  letter-spacing: 1rpx;
}

.elf-new-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 10rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(180deg, #6c4ad6 0%, #4d2eb1 100%);
  border-radius: 6rpx;
  box-shadow: 0 4rpx 8rpx rgba(76, 46, 177, 0.3);
  letter-spacing: 1rpx;
  z-index: 2;
}

.elf-avatar-wrap {
  width: 110rpx;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
  margin-bottom: 8rpx;
}

.elf-avatar {
  width: 110rpx;
  height: 110rpx;
}

.elf-avatar-fallback {
  font-size: 38rpx;
  font-weight: bold;
  color: #b08a4d;
}

.elf-name {
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #2c2236;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 6rpx;
  box-sizing: border-box;
}

.elf-type {
  margin-top: 6rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  color: #333333;
  background: #f7dcb3;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.elf-type-icon {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

.elf-stage {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 14rpx;
  font-size: 18rpx;
  color: #5b4a82;
  background: rgba(91, 74, 130, 0.1);
  border: 1rpx solid rgba(91, 74, 130, 0.22);
  border-radius: 999rpx;
}

.elf-stage-text {
  font-size: 18rpx;
  line-height: 1;
}

/* ---------- Empty / Load more ---------- */

.empty-state {
  text-align: center;
  padding: 120rpx 0 80rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
}

.load-more-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
  padding: 24rpx 0 10rpx;
}
