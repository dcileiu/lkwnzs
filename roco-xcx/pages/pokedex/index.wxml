<view class="page-container">
  <view class="page-inner">
    <view class="pokedex-stats">
      <view class="stat-item">
        <text class="stat-num">{{totalCount}}</text>
        <text class="stat-label">图鉴总数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{collectedCount}}</text>
        <text class="stat-label">已收录</text>
      </view>
    </view>

    <view class="sticky-filter-bar">
      <view class="search-box">
        <icon type="search" size="14" color="#999"></icon>
        <input
          class="search-input"
          placeholder="搜索精灵名称"
          confirm-type="search"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
          value="{{keyword}}"
        />
      </view>

      <scroll-view class="element-tabs" scroll-x enable-flex show-scrollbar="false">
        <view class="tabs-wrap">
          <block wx:for="{{elements}}" wx:key="name">
            <view
              class="tab-item {{currentElement === item.name ? 'active' : ''}}"
              data-element="{{item.name}}"
              bindtap="switchElement"
            >
              <image wx:if="{{item.iconUrl}}" class="tab-icon" src="{{item.iconUrl}}" mode="aspectFit"></image>
              <text>{{item.name}}</text>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{elves.length}}" class="elf-grid">
      <block wx:for="{{elves}}" wx:key="id">
        <view class="elf-card" bindtap="goToDetail" data-id="{{item.id}}">
          <view class="elf-avatar-wrap">
            <image
              wx:if="{{item.displayImage}}"
              src="{{item.displayImage}}"
              class="elf-avatar"
              mode="aspectFit"
              binderror="onElfImageError"
              data-id="{{item.id}}"
            ></image>
            <text wx:else class="elf-avatar-fallback">{{item.avatarText}}</text>
          </view>
          <text class="elf-name">{{item.name}}</text>
          <view class="elf-tags">
            <block wx:for="{{item.elements}}" wx:key="*this">
              <text class="tag-element">{{item}}系</text>
            </block>
            <text class="tag-rarity {{item.rarity}}">{{item.rarity}}</text>
          </view>
        </view>
      </block>
    </view>

    <view wx:else class="empty-state">暂时没有符合条件的精灵</view>
    <view wx:if="{{elves.length}}" class="load-more-tip">{{hasMore ? (isLoadingMore ? "加载中..." : "上拉加载更多") : "没有更多精灵了"}}</view>
  </view>
</view>
