.page-container {
  width: 100%;
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.8), rgba(30, 58, 100, 0.8)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  box-sizing: border-box;
}

.hero {
  position: relative;
  min-height: 332rpx;
  border-radius: 0 0 22rpx 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-bg {
  display: block;
  width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0) 45%,
    rgba(25, 51, 93, 0.35) 65%,
    rgba(25, 51, 93, 0.75) 85%,
    #19335d 100%
  );
}

.nav-back {
  position: absolute;
  top: calc(env(safe-area-inset-bottom) + 40rpx);
  left: 22rpx;
  z-index: 5;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15),
    0 8rpx 16rpx rgba(8, 20, 48, 0.25);
}

.nav-back-icon {
  color: #ffe6b8;
  font-size: 50rpx;
  line-height: 1;
  margin-right: 2rpx;
}

.detail-main {
  position: relative;
  z-index: 3;
  margin-top: -140rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.loading-state {
  padding: 160rpx 0;
  color: rgba(255, 255, 255, 0.62);
  font-size: 28rpx;
  text-align: center;
}

.detail-page {
  padding-top: 24rpx;
  box-sizing: border-box;
}

/* ---------- Card frame ---------- */

.hero-card,
.section-card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 40rpx 34rpx;
  border-radius: 22rpx;
  background-image: url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/elf-detail.webp");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  box-sizing: border-box;
}

.section-card {
  min-height: 520rpx;
}

/* ---------- Hero ---------- */

.hero-main {
  display: flex;
  align-items: stretch;
  gap: 22rpx;
}

.hero-media {
  width: 220rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-image-wrap {
  width: 220rpx;
  height: 240rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(
      120% 80% at 50% 100%,
      rgba(120, 168, 240, 0.45) 0%,
      rgba(31, 55, 110, 0) 70%
    ),
    linear-gradient(
      180deg,
      rgba(50, 82, 150, 0.55) 0%,
      rgba(20, 38, 78, 0.7) 100%
    );
  border: 1rpx solid rgba(255, 215, 130, 0.32);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08),
    inset 0 -10rpx 18rpx rgba(0, 0, 0, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-egg-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 14rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(20, 38, 78, 0.5);
  border: 1rpx solid rgba(255, 215, 130, 0.28);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.hero-egg-label {
  display: block;
  margin-bottom: 6rpx;
  color: #ffd680;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  text-align: center;
}

.hero-egg-image {
  width: 100%;
  height: 96rpx;
}

.hero-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hero-title-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.hero-title {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.35);
}

.hero-hot {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff9d3a 0%, #ff785a 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(255, 110, 60, 0.35);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.hero-tags-main {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
}

.hero-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  line-height: 1.5;
}

.hero-tag.tag-element {
  background: linear-gradient(
    180deg,
    rgba(140, 215, 255, 0.95) 0%,
    rgba(99, 187, 235, 0.95) 100%
  );
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(70, 150, 220, 0.45);
}

.hero-tag.tag-rarity {
  background: linear-gradient(180deg, #b18cff 0%, #8a6cf0 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(120, 92, 220, 0.45);
}

.hero-tag.tag-category {
  background: rgba(20, 38, 78, 0.55);
  color: #ffe0a8;
  border: 1rpx solid rgba(255, 215, 130, 0.4);
}

/* ---------- Stats ---------- */

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 4rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(20, 38, 78, 0.45);
  border: 1rpx solid rgba(255, 215, 130, 0.18);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

.stat-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.stat-label {
  color: #b9c8e5;
  font-size: 20rpx;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}

.stat-value {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  word-break: break-all;
}

.stat-icon {
  font-size: 30rpx;
  line-height: 1;
  opacity: 0.78;
  flex-shrink: 0;
  margin-left: 4rpx;
}

/* ---------- Section ---------- */

.section-head {
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  color: #ffe9b8;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.35);
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  text-align: center;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.group-card {
  display: flex;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(20, 38, 78, 0.55);
  border: 1rpx solid rgba(255, 215, 130, 0.28);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.group-card-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  flex-shrink: 0;
}

.group-card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.group-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.group-card-name {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.group-card-rarity {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 215, 130, 0.16);
  color: #ffd680;
  font-size: 20rpx;
  font-weight: 600;
}

.group-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.group-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(140, 215, 255, 0.18);
  color: #9fdcff;
  font-size: 20rpx;
  font-weight: 600;
}

.empty-state {
  padding: 120rpx 0 40rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 28rpx;
  text-align: center;
}

