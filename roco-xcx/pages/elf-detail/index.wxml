<template name="evolutionNode">
  <view class="tree-node">
    <view
      class="tree-card {{node.childElfId === currentElfId ? 'is-current' : ''}}"
      bindtap="openElf"
      data-id="{{node.childElfId}}"
    >
      <image
        class="tree-card-image"
        src="{{node.elf.coverImage || node.elf.avatar || '/assets/default-elf.png'}}"
        mode="aspectFit"
      ></image>
      <view class="tree-card-body">
        <view class="tree-card-head">
          <text class="tree-card-name">{{node.elf.name}}</text>
          <text class="tree-stage">第{{node.stage}}阶段</text>
        </view>
        <view class="tree-tags">
          <block wx:for="{{node.elf.elements}}" wx:key="*this">
            <text class="tree-tag tree-tag-element">{{item}}系</text>
          </block>
          <text class="tree-tag tree-tag-rarity">{{node.elf.rarity}}</text>
        </view>
        <text wx:if="{{node.requirement}}" class="tree-note">进化条件：{{node.requirement}}</text>
        <text wx:if="{{node.note}}" class="tree-note secondary">{{node.note}}</text>
      </view>
    </view>

    <view wx:if="{{node.children && node.children.length}}" class="tree-children-wrap">
      <view class="tree-vertical"></view>
      <view class="tree-children">
        <block wx:for="{{node.children}}" wx:key="id">
          <view class="tree-child-item">
            <view class="tree-child-line"></view>
            <template is="evolutionNode" data="{{node: item, currentElfId: currentElfId}}" />
          </view>
        </block>
      </view>
    </view>
  </view>
</template>

<view class="page-container">
  <view wx:if="{{!elf}}" class="loading-state">正在加载精灵资料...</view>

  <view wx:else class="detail-page">
    <view class="hero-card">
      <view class="hero-main">
        <image
          class="hero-image"
          src="{{activeImage || elf.coverImage || elf.avatar || '/assets/default-elf.png'}}"
          mode="aspectFit"
        ></image>

        <view class="hero-body">
          <view class="hero-title-row">
            <text class="hero-title">{{elf.name}}</text>
            <text wx:if="{{elf.isHot}}" class="hero-hot">热门</text>
          </view>

          <view class="hero-tags">
            <block wx:for="{{elf.elements}}" wx:key="*this">
              <text class="hero-tag">{{item}}系</text>
            </block>
            <text class="hero-tag">{{elf.rarity}}</text>
          </view>

          <view class="stats-grid">
            <view class="stat-item">
              <text class="stat-label">总和</text>
              <text class="stat-value">{{elf.totalStats}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">生命</text>
              <text class="stat-value">{{elf.hp}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">攻击</text>
              <text class="stat-value">{{elf.attack}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">防御</text>
              <text class="stat-value">{{elf.defense}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">速度</text>
              <text class="stat-value">{{elf.speed}}</text>
            </view>
          </view>
        </view>
      </view>

      <scroll-view wx:if="{{galleryImages.length}}" class="gallery-strip" scroll-x>
        <view class="gallery-track">
          <block wx:for="{{galleryImages}}" wx:key="id">
            <view
              class="gallery-thumb {{activeImage === item.url ? 'active' : ''}}"
              bindtap="selectImage"
              data-url="{{item.url}}"
            >
              <image class="gallery-thumb-image" src="{{item.url}}" mode="aspectFill"></image>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">进化路线</text>
        <text class="section-sub">同一只精灵可以在进化链中出现多个分支</text>
      </view>

      <view wx:if="{{evolutionRoots.length}}" class="tree-shell">
        <block wx:for="{{evolutionRoots}}" wx:key="id">
          <template is="evolutionNode" data="{{node: item, currentElfId: elf.id}}" />
        </block>
      </view>

      <view wx:else class="empty-state">暂未配置该精灵的进化路线</view>
    </view>
  </view>
</view>
