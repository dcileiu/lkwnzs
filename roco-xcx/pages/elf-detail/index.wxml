<view class="page-container">
  <view wx:if="{{!elf}}" class="loading-state">正在加载精灵资料...</view>

  <view wx:else class="detail-page">
    <view class="hero-card">
      <view class="hero-main">
        <view class="hero-media">
          <image
            class="hero-image"
            src="{{activeImage || '/assets/default-elf.png'}}"
            mode="aspectFit"
            binderror="onHeroImageError"
          ></image>

          <view wx:if="{{elf.eggImageUrl}}" class="hero-egg-panel">
            <text class="hero-egg-label">精灵蛋</text>
            <image class="hero-egg-image" src="{{elf.eggImageUrl}}" mode="aspectFit"></image>
          </view>
        </view>

        <view class="hero-body">
          <view class="hero-title-row">
            <text class="hero-title">{{elf.name}}</text>
            <text wx:if="{{elf.isHot}}" class="hero-hot">热门</text>
          </view>

          <view class="hero-tags">
            <block wx:for="{{elf.elements}}" wx:key="*this">
              <text class="hero-tag">{{item}}系</text>
            </block>
            <text class="hero-tag">{{elf.rarity}}</text>
            <text wx:if="{{elf.category}}" class="hero-tag category">分类：{{elf.category}}</text>
            <text wx:if="{{elf.group}}" class="hero-tag group">组别：{{elf.group}}</text>
          </view>

          <view class="stats-grid">
            <view class="stat-item">
              <text class="stat-label">身高</text>
              <text class="stat-value">{{elf.height || '-'}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">体重</text>
              <text class="stat-value">{{elf.weight || '-'}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">种族值</text>
              <text class="stat-value">{{elf.raceValue || '-'}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">基础四维</text>
              <text class="stat-value">{{elf.totalStats}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">生命</text>
              <text class="stat-value">{{elf.hp}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">攻击</text>
              <text class="stat-value">{{elf.attack}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">防御</text>
              <text class="stat-value">{{elf.defense}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">速度</text>
              <text class="stat-value">{{elf.speed}}</text>
            </view>
          </view>
        </view>
      </view>

      <scroll-view wx:if="{{galleryImages.length}}" class="gallery-strip" scroll-x>
        <view class="gallery-track">
          <block wx:for="{{galleryImages}}" wx:key="id">
            <view
              class="gallery-thumb {{activeImage === item.url ? 'active' : ''}}"
              bindtap="selectImage"
              data-url="{{item.url}}"
            >
              <image class="gallery-thumb-image" src="{{item.url}}" mode="aspectFill"></image>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">同组精灵</text>
        <text class="section-sub">按精灵组字段自动关联展示</text>
      </view>

      <view wx:if="{{relatedElves.length}}" class="group-list">
        <block wx:for="{{relatedElves}}" wx:key="id">
          <view class="group-card" bindtap="openElf" data-id="{{item.id}}">
            <image
              class="group-card-image"
              src="{{item.coverImage || item.avatar || '/assets/default-elf.png'}}"
              mode="aspectFit"
            ></image>
            <view class="group-card-body">
              <view class="group-card-head">
                <text class="group-card-name">{{item.name}}</text>
                <text class="group-card-rarity">{{item.rarity}}</text>
              </view>
              <view class="group-tags">
                <block wx:for="{{item.elements}}" wx:key="*this">
                  <text class="group-tag">{{item}}系</text>
                </block>
              </view>
            </view>
          </view>
        </block>
      </view>

      <view wx:else class="empty-state">该精灵暂时没有同组成员</view>
    </view>
  </view>
</view>
