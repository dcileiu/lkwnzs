<template name="evolutionNode">
  <view class="tree-node">
    <view class="tree-card {{currentElfId === node.childElfId ? 'is-current' : ''}}" bindtap="openElf" data-id="{{node.childElfId}}">
      <image class="tree-card-image" src="{{node.elf.coverImage || node.elf.avatar || '/assets/default-elf.png'}}" mode="aspectFill"></image>
      <view class="tree-card-body">
        <view class="tree-card-head">
          <text class="tree-card-name">{{node.elf.name}}</text>
          <text class="tree-stage">第{{node.stage}}阶段</text>
        </view>
        <view class="tree-tags">
          <text class="tree-tag tree-tag-element">{{node.elf.element}}</text>
          <text class="tree-tag tree-tag-rarity">{{node.elf.rarity}}</text>
        </view>
        <text wx:if="{{node.requirement}}" class="tree-note">进化条件：{{node.requirement}}</text>
        <text wx:if="{{node.note}}" class="tree-note secondary">{{node.note}}</text>
      </view>
    </view>

    <view wx:if="{{node.children && node.children.length}}" class="tree-children-wrap">
      <view class="tree-vertical"></view>
      <view class="tree-children">
        <block wx:for="{{node.children}}" wx:key="id">
          <view class="tree-child-item">
            <view class="tree-child-line"></view>
            <template is="evolutionNode" data="{{node:item,currentElfId:currentElfId}}"></template>
          </view>
        </block>
      </view>
    </view>
  </view>
</template>

<scroll-view class="page-container" scroll-y>
  <view wx:if="{{elf}}" class="detail-page">
    <view class="hero-card">
      <view class="hero-main">
        <image class="hero-image" src="{{activeImage || elf.coverImage || '/assets/default-elf.png'}}" mode="aspectFill"></image>
        <view class="hero-body">
          <view class="hero-title-row">
            <text class="hero-title">{{elf.name}}</text>
            <text wx:if="{{elf.isHot}}" class="hero-hot">HOT</text>
          </view>
          <view class="hero-tags">
            <text class="hero-tag">{{elf.element}}</text>
            <text class="hero-tag">{{elf.rarity}}</text>
          </view>
          <view class="stats-grid">
            <view class="stat-item">
              <text class="stat-label">HP</text>
              <text class="stat-value">{{elf.hp}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">攻击</text>
              <text class="stat-value">{{elf.attack}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">防御</text>
              <text class="stat-value">{{elf.defense}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">速度</text>
              <text class="stat-value">{{elf.speed}}</text>
            </view>
          </view>
        </view>
      </view>

      <scroll-view wx:if="{{galleryImages.length > 0}}" class="gallery-strip" scroll-x>
        <view class="gallery-track">
          <block wx:for="{{galleryImages}}" wx:key="id">
            <view class="gallery-thumb {{activeImage === item.url ? 'active' : ''}}" bindtap="selectImage" data-url="{{item.url}}">
              <image class="gallery-thumb-image" src="{{item.url}}" mode="aspectFill"></image>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">进化树</text>
        <text class="section-sub">支持单链和多分支进化路线</text>
      </view>

      <view wx:if="{{evolutionRoots.length === 0}}" class="empty-state">
        暂未配置进化路线
      </view>

      <view wx:else class="tree-shell">
        <block wx:for="{{evolutionRoots}}" wx:key="id">
          <template is="evolutionNode" data="{{node:item,currentElfId:elf.id}}"></template>
        </block>
      </view>
    </view>
  </view>

  <view wx:else class="loading-state">加载中...</view>
</scroll-view>
