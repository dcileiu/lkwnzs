<view class="page-container">
  <view class="hero">
    <image class="hero-bg" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/articles-bg.webp" mode="widthFix"></image>
    <view class="hero-overlay"></view>

    <view class="top-nav" style="padding-top: {{navTopPadding}}px;">
      <view class="nav-btn nav-back" bindtap="onBackTap">
        <image class="nav-back-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/bg-left.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">✦ {{title}} ✦</text>
    </view>
  </view>

  <view class="content-area">
    <view wx:if="{{articles.length === 0 && !loading}}" class="empty-state">暂无文章记录</view>

    <block wx:for="{{articles}}" wx:key="id">
      <view class="history-hot-card" bindtap="openArticle" data-id="{{item.id}}">
        <image class="history-hot-thumb" src="{{item.thumbnail || 'https://wallpaper.cdn.itianci.cn/imgs/miniapp/default-article.png'}}" mode="aspectFill" lazy-load></image>
        <view class="history-hot-info">
          <view class="history-hot-title line-clamp-2">{{item.title}}</view>
          <view class="history-hot-summary line-clamp-1">{{item.summary || (item.category || '未分类')}}</view>
          <view class="history-hot-stats">
            <view class="history-hot-stats-item">
              <image class="history-hot-stats-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/see.svg" mode="aspectFit"></image>
              <text>{{item.views}}</text>
            </view>
            <view class="history-hot-stats-item">
              <image class="history-hot-stats-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/approve.svg" mode="aspectFit"></image>
              <text>{{item.likes}}</text>
            </view>
            <view class="history-hot-stats-item">
              <image class="history-hot-stats-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/collect.svg" mode="aspectFit"></image>
              <text>{{item.favorites || item.likes || 0}}</text>
            </view>
            <view class="history-hot-stats-item">
              <image class="history-hot-stats-icon" src="https://wallpaper.cdn.itianci.cn/imgs/miniapp/comment.svg" mode="aspectFit"></image>
              <text>{{item.commentCount}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{loading && articles.length === 0}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>

