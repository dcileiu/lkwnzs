.page-container {
  width: 100%;
  min-height: 100vh;
  background: #19335d;
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  background-image:
    linear-gradient(rgba(30, 58, 100, 0.45), rgba(30, 58, 100, 0.45)),
    url("https://wallpaper.cdn.itianci.cn/imgs/miniapp/bgi.webp");
  background-size: cover, cover;
  background-repeat: no-repeat, no-repeat;
  background-position:
    center top,
    center top;
  box-sizing: border-box;
}

.content-area {
  margin-top: -20rpx;
  padding: 0 18rpx 20rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  height: 460rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  max-width: 100%;
  height: auto;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(25, 51, 93, 0) 0%,
    rgba(25, 51, 93, 0) 45%,
    rgba(25, 51, 93, 0.35) 65%,
    rgba(25, 51, 93, 0.75) 85%,
    #0f1f3e 100%
  );
}

.top-nav {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 0 200rpx 0 20rpx;
}

.nav-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(20, 43, 82, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-sizing: border-box;
}

.nav-back-icon {
  width: 58rpx;
  height: 58rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 360rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #f9eec4;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 4rpx 14rpx rgba(8, 16, 36, 0.45);
  pointer-events: none;
}

.content-area {
  position: relative;
  top: -100rpx;
  padding: 0 20rpx 20rpx;
  box-sizing: border-box;
}

.empty-state {
  margin-top: 24rpx;
  padding: 120rpx 0;
  text-align: center;
  color: #f8f3e6;
  font-size: 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(
    180deg,
    rgba(34, 64, 120, 0.98) 0%,
    rgba(42, 67, 117, 0.98) 100%
  );
  box-shadow:
    inset 0 0 0 1rpx rgba(193, 213, 255, 0.14),
    0 10rpx 22rpx rgba(9, 23, 55, 0.18);
  box-sizing: border-box;
}

.history-hot-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(
    180deg,
    rgba(34, 64, 120, 0.98) 0%,
    rgba(42, 67, 117, 0.98) 100%
  );
  box-shadow:
    inset 0 0 0 1rpx rgba(193, 213, 255, 0.14),
    0 10rpx 22rpx rgba(9, 23, 55, 0.18);
  box-sizing: border-box;
}

.history-hot-thumb {
  width: 200rpx;
  height: 144rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.history-hot-info {
  flex: 1;
  min-width: 0;
}

.history-hot-title {
  font-size: 26rpx;
  line-height: 1.46;
  font-weight: 700;
  color: #f8f3e6;
}

.history-hot-summary {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(217, 229, 255, 0.7);
}

.history-hot-stats {
  display: flex;
  gap: 18rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(217, 229, 255, 0.78);
}

.history-hot-stats-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.history-hot-stats-icon {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.line-clamp-1,
.line-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.line-clamp-1 {
  -webkit-line-clamp: 1;
}

.line-clamp-2 {
  -webkit-line-clamp: 2;
}

.loading-state {
  min-height: 40vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(224, 233, 255, 0.72);
  font-size: 28rpx;
}
